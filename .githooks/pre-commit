#!/usr/bin/env bash
# .githooks/pre-commit
# ═══════════════════════════════════════════════════════════════════════════
# Homey App Mandatory Files Pre-Commit Hook (v9.0.22 — 8 Layers)
# Runs ALL mandatory checks before every git commit.
# Blocks commit if any error is found.
#
# INSTALL: git config core.hooksPath .githooks
# Or run:  npm run hooks:install
# ═══════════════════════════════════════════════════════════════════════════

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
RESET='\033[0m'

TOTAL_CHECKS=9
ERRORS=0

echo ""
echo -e "${CYAN}╔══════════════════════════════════════════════════════════════╗${RESET}"
echo -e "${CYAN}║     HOMEY PRE-COMMIT CHECK (v9.0.22 — 8 Layers)            ║${RESET}"
echo -e "${CYAN}╚══════════════════════════════════════════════════════════════╝${RESET}"
echo ""

ROOT="$(git rev-parse --show-toplevel)"

# ─── 1. Run mandatory check ──────────────────────────────────────────────────
echo -e "${CYAN}[1/$TOTAL_CHECKS] Running comprehensive mandatory file check...${RESET}"
if ! node "$ROOT/scripts/validate/homey-mandatory-check.js" --quiet; then
  echo ""
  echo -e "${RED}  COMMIT BLOCKED — Mandatory file check FAILED${RESET}"
  echo -e "${YELLOW}  Run: node scripts/validate/homey-mandatory-check.js${RESET}"
  echo -e "${YELLOW}  Fix: node scripts/validate/homey-mandatory-check.js --fix${RESET}"
  ERRORS=$((ERRORS + 1))
else
  echo -e "${GREEN}  PASSED: Mandatory file check${RESET}"
fi

# ─── 2. Quick JSON syntax check on staged files ───────────────────────────────
echo -e "${CYAN}[2/$TOTAL_CHECKS] Checking staged JSON files...${RESET}"
STAGED_JSON=$(git diff --cached --name-only --diff-filter=ACM | grep '\.json$' || true)
JSON_ERRORS=0
if [ -n "$STAGED_JSON" ]; then
  while IFS= read -r file; do
    if [ -f "$ROOT/$file" ]; then
      if ! node -e "JSON.parse(require('fs').readFileSync('$ROOT/$file','utf8'))" 2>/dev/null; then
        echo -e "${RED}  Invalid JSON: $file${RESET}"
        JSON_ERRORS=$((JSON_ERRORS + 1))
      fi
    fi
  done <<< "$STAGED_JSON"
fi
if [ $JSON_ERRORS -gt 0 ]; then
  echo -e "${RED}  COMMIT BLOCKED — $JSON_ERRORS staged JSON file(s) have invalid syntax${RESET}"
  ERRORS=$((ERRORS + 1))
else
  echo -e "${GREEN}  PASSED: Staged JSON files OK${RESET}"
fi

# ─── 3. Check version consistency if app.json is staged ──────────────────────
echo -e "${CYAN}[3/$TOTAL_CHECKS] Checking version consistency...${RESET}"
if git diff --cached --name-only | grep -q "app.json"; then
  APP_VER=$(node -p "require('$ROOT/app.json').version" 2>/dev/null || echo "unknown")
  PKG_VER=$(node -p "require('$ROOT/package.json').version" 2>/dev/null || echo "unknown")
  if [ "$APP_VER" != "$PKG_VER" ] && [ "$PKG_VER" != "unknown" ]; then
    echo -e "${YELLOW}  Version mismatch: app.json=$APP_VER vs package.json=$PKG_VER${RESET}"
    echo -e "${YELLOW}  Auto-fixing package.json version...${RESET}"
    node -e "
      const fs = require('fs');
      const pkg = JSON.parse(fs.readFileSync('$ROOT/package.json','utf8'));
      pkg.version = require('$ROOT/app.json').version;
      fs.writeFileSync('$ROOT/package.json', JSON.stringify(pkg, null,2)+'\\n','utf8');
    " && git add "$ROOT/package.json"
    echo -e "${GREEN}  PASSED: package.json version synced${RESET}"
  else
    echo -e "${GREEN}  PASSED: Version consistent: $APP_VER${RESET}"
  fi
else
  echo -e "${GREEN}  PASSED: Version check skipped (app.json not staged)${RESET}"
fi

# ─── 4. Warn on .homeyignore changes (high risk) ─────────────────────────────
echo -e "${CYAN}[4/$TOTAL_CHECKS] Checking for high-risk staged files...${RESET}"
if git diff --cached --name-only | grep -q ".homeyignore"; then
  echo -e "${YELLOW}  WARNING: .homeyignore is staged for commit!${RESET}"
  echo -e "${YELLOW}  Verify these rules are NOT added:${RESET}"
  echo -e "${YELLOW}  - *.json  (excludes runtime fingerprints.json)${RESET}"
  echo -e "${YELLOW}  - README.txt  (required by SDK App.js:1427)${RESET}"
  echo -e "${YELLOW}  - data/fingerprints.json  (required by DeviceFingerprintDB.js)${RESET}"
  JSONWILD=$(grep -E '^[*][.]json$' "$ROOT/.homeyignore" 2>/dev/null || true)
  README_EXCL=$(grep -E '^README[.]txt$' "$ROOT/.homeyignore" 2>/dev/null || true)
  if [ -n "$JSONWILD" ]; then
    echo -e "${RED}  BLOCKED: .homeyignore has *.json wildcard!${RESET}"
    ERRORS=$((ERRORS + 1))
  elif [ -n "$README_EXCL" ]; then
    echo -e "${RED}  BLOCKED: .homeyignore excludes README.txt (required by SDK)!${RESET}"
    ERRORS=$((ERRORS + 1))
  else
    echo -e "${GREEN}  PASSED: .homeyignore has no dangerous wildcards${RESET}"
  fi
else
  echo -e "${GREEN}  PASSED: .homeyignore not modified${RESET}"
fi

# ─── 5. Check for empty manufacturerName arrays (AggregateError prevention) ──
echo -e "${CYAN}[5/$TOTAL_CHECKS] Checking for empty manufacturerName arrays...${RESET}"
STAGED_DRIVERS=$(git diff --cached --name-only --diff-filter=ACM | grep 'driver\.compose\.json$' || true)
MFR_ERRORS=0
if [ -n "$STAGED_DRIVERS" ]; then
  while IFS= read -r file; do
    if [ -f "$ROOT/$file" ]; then
      # Check for empty manufacturerName arrays in zigbee sections
      EMPTY_MFR=$(node -e "
        const d = JSON.parse(require('fs').readFileSync('$ROOT/$file','utf8'));
        const zig = d.zigbee || {};
        if (Array.isArray(zig.manufacturerName) && zig.manufacturerName.length === 0) {
          console.log('empty');
        }
      " 2>/dev/null || true)
      if [ "$EMPTY_MFR" = "empty" ]; then
        echo -e "${RED}  BLOCKED: $file has manufacturerName: [] (causes AggregateError)${RESET}"
        MFR_ERRORS=$((MFR_ERRORS + 1))
      fi
      SYNTHETIC_MFR=$(node -e "
        const d = JSON.parse(require('fs').readFileSync('$ROOT/$file','utf8'));
        const zig = d.zigbee || {};
        const re = /unknown|dummy|placeholder|needs_device_assignment|^_generic_|^_GENERIC_|^_hybrid_|^_HYBRID_|^_master_|^_MASTER_/;
        const bad = Array.isArray(zig.manufacturerName) ? zig.manufacturerName.filter(v => typeof v === 'string' && re.test(v)) : [];
        if (bad.length) console.log(bad.slice(0, 3).join(', '));
      " 2>/dev/null || true)
      if [ -n "$SYNTHETIC_MFR" ]; then
        echo -e "${YELLOW}  WARNING: $file has synthetic manufacturerName entries: $SYNTHETIC_MFR${RESET}"
        echo -e "${YELLOW}           They must be pruned by prepare-publish to reduce Athom upload size.${RESET}"
      fi
    fi
  done <<< "$STAGED_DRIVERS"
fi
if [ $MFR_ERRORS -gt 0 ]; then
  echo -e "${YELLOW}  WARNING — $MFR_ERRORS driver(s) with empty manufacturerName (warning only)${RESET}"
  echo -e "${YELLOW}  NOTE: empty manufacturerName:[] is accepted by 'homey app validate --level publish'.${RESET}"
  echo -e "${YELLOW}  The earlier AggregateError link was disproven by the A/B test (good build also fails).${RESET}"
else
  echo -e "${GREEN}  PASSED: No empty manufacturerName arrays${RESET}"
fi

# ─── 6. Check for missing driver assets ──────────────────────────────────────
echo -e "${CYAN}[6/$TOTAL_CHECKS] Checking for missing driver assets...${RESET}"
STAGED_DRIVER_DIRS=$(git diff --cached --name-only --diff-filter=ACM | grep '^drivers/[^/]*/driver\.compose\.json$' | sed 's|/driver\.compose\.json||' || true)
ASSET_ERRORS=0
if [ -n "$STAGED_DRIVER_DIRS" ]; then
  while IFS= read -r dir; do
    if [ -d "$ROOT/$dir" ]; then
      MISSING=""
      for asset in "driver.js" "device.js" "driver.compose.json"; do
        if [ ! -f "$ROOT/$dir/$asset" ]; then
          MISSING="$MISSING $asset"
        fi
      done
      if [ -n "$MISSING" ]; then
        echo -e "${YELLOW}  WARNING: $dir missing:$MISSING${RESET}"
        ASSET_ERRORS=$((ASSET_ERRORS + 1))
      fi
    fi
  done <<< "$STAGED_DRIVER_DIRS"
fi
if [ $ASSET_ERRORS -gt 0 ]; then
  echo -e "${YELLOW}  WARNING: $ASSET_ERRORS driver directory(ies) have missing assets (non-blocking)${RESET}"
else
  echo -e "${GREEN}  PASSED: All staged driver directories have required assets${RESET}"
fi

# ─── 7. Check for console.log in staged driver files ─────────────────────────
echo -e "${CYAN}[7/$TOTAL_CHECKS] Checking for console.log in staged drivers...${RESET}"
STAGED_JS_DRIVERS=$(git diff --cached --name-only --diff-filter=ACM | grep '^drivers/.*\.js$' || true)
CONSOLE_ERRORS=0
if [ -n "$STAGED_JS_DRIVERS" ]; then
  while IFS= read -r file; do
    if [ -f "$ROOT/$file" ]; then
      # Count console.log/warn/error but skip lines that are comments
      VIOLATIONS=$(grep -n 'console\.\(log\|warn\|error\)' "$ROOT/$file" 2>/dev/null | grep -v '^[0-9]*:[[:space:]]*//' | grep -v '^[0-9]*:[[:space:]]*\*' || true)
      if [ -n "$VIOLATIONS" ]; then
        echo -e "${YELLOW}  console.log found in $file:${RESET}"
        echo "$VIOLATIONS" | head -3 | while IFS= read -r line; do
          echo -e "${YELLOW}    $line${RESET}"
        done
        CONSOLE_ERRORS=$((CONSOLE_ERRORS + 1))
      fi
    fi
  done <<< "$STAGED_JS_DRIVERS"
fi
if [ $CONSOLE_ERRORS -gt 0 ]; then
  echo -e "${YELLOW}  WARNING: $CONSOLE_ERRORS driver file(s) use console.log (non-blocking, prefer Homey logger)${RESET}"
else
  echo -e "${GREEN}  PASSED: No console.log in staged driver files${RESET}"
fi

# ─── 8. Publish payload size gate ────────────────────────────────────────────
echo -e "${CYAN}[8/$TOTAL_CHECKS] Checking publish payload size gates...${RESET}"
if ! node "$ROOT/scripts/ci/publish-size-gate.cjs"; then
  echo -e "${RED}  COMMIT BLOCKED — Publish payload size gate FAILED${RESET}"
  echo -e "${YELLOW}  Run: npm run build && npm run prepare-publish${RESET}"
  ERRORS=$((ERRORS + 1))
else
  echo -e "${GREEN}  PASSED: Publish payload size gates${RESET}"
fi

# ─── 9. Security scan on staged .js files ────────────────────────────────────
echo -e "${CYAN}[9/$TOTAL_CHECKS] Security scan on staged JS files...${RESET}"
STAGED_JS=$(git diff --cached --name-only --diff-filter=ACM | grep '\.js$' | grep -v 'node_modules/' | grep -v '.github/scripts/temp/' || true)
SEC_ERRORS=0
if [ -n "$STAGED_JS" ]; then
  while IFS= read -r file; do
    if [ -f "$ROOT/$file" ]; then
      # Check for eval() usage (security risk)
      if grep -q 'eval(' "$ROOT/$file" 2>/dev/null; then
        echo -e "${RED}  SECURITY: eval() found in $file${RESET}"
        SEC_ERRORS=$((SEC_ERRORS + 1))
      fi
      # Check for hardcoded API keys / tokens (but skip comments)
      HARDKEYS=$(grep -n -E '(sk-[a-zA-Z0-9]{20,}|ghp_[a-zA-Z0-9]{36}|AKIA[0-9A-Z]{16})' "$ROOT/$file" 2>/dev/null | grep -v '^[0-9]*:[[:space:]]*//' | grep -v '^[0-9]*:[[:space:]]*\*' || true)
      if [ -n "$HARDKEYS" ]; then
        echo -e "${RED}  SECURITY: Hardcoded secret found in $file${RESET}"
        SEC_ERRORS=$((SEC_ERRORS + 1))
      fi
    fi
  done <<< "$STAGED_JS"
fi
if [ $SEC_ERRORS -gt 0 ]; then
  echo -e "${RED}  COMMIT BLOCKED — $SEC_ERRORS security issue(s) found!${RESET}"
  ERRORS=$((ERRORS + 1))
else
  echo -e "${GREEN}  PASSED: No security issues in staged JS files${RESET}"
fi

# ─── Summary ─────────────────────────────────────────────────────────────────
echo ""
if [ $ERRORS -gt 0 ]; then
  echo -e "${RED}╔══════════════════════════════════════════════════════════════╗${RESET}"
  echo -e "${RED}║  COMMIT BLOCKED — $ERRORS check(s) FAILED                     ║${RESET}"
  echo -e "${RED}╚══════════════════════════════════════════════════════════════╝${RESET}"
  echo ""
  exit 1
else
  echo -e "${GREEN}╔══════════════════════════════════════════════════════════════╗${RESET}"
  echo -e "${GREEN}║  ALL $TOTAL_CHECKS PRE-COMMIT CHECKS PASSED — Commit allowed     ║${RESET}"
  echo -e "${GREEN}╚══════════════════════════════════════════════════════════════╝${RESET}"
  echo ""
  exit 0
fi
