    }
  ],
  "tokens": [
    {
      "name": "zone_name",
      "type": "string",
      "title": {
        "en": "Zone name"
      }
    },
    {
      "name": "new_state",
      "type": "string",
      "title": {
        "en": "New state"
      }
    }
  ]
