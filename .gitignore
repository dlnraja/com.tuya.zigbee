# === TEMPORARY FILES ===
NUL
_proxima/
tmp/
temp/
*.tmp
*.temp

# === SENSITIVE DATA ===
*secret*
*password*
*.key

# === IDE & EDITOR ===
.vscode/
.idea/
*.swp
*.swo
*~

# === TESTING ===
test/
tests/
coverage/

