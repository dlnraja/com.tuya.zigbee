{
  "id": "rgb_led_light_bar",
  "name": {
    "en": "RGB Led Light Bar"
  },
  "$extends": [
    "light_color_ambiance"
  ],
  "energy": {
    "approximation": {
      "usageOn": 8,
      "usageOff": 0.2
    }
  },
  "zigbee": {
    "manufacturerName": [
      "_TZ3000_gek6snaj"
    ],
    "productId": [
      "TS0505A",
      "TS0505B"
    ],
    "endpoints": {
      "1": {
        "clusters": [
          0,
          3,
          4,
          5,
          6,
          8,
          768
        ],
        "bindings": [
          6,
          8,
          768
        ]
      }
    },
    "learnmode": {
      "image": "{{driverAssetsPath}}/icon.svg",
      "instruction": {
        "en": "Power on to enter pairing mode."
      }
    }
  },
  "version": "1.0.0",
  "connectivity": [
    "zigbee"
  ],
  "capabilities": [
    "onoff",
    "dim",
    "light_hue",
    "light_saturation",
    "button.1"
