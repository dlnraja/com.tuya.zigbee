{
  "name": {
    "en": "Outdoor Light Sensor",
    "fr": "Capteur de Luminosité Extérieur",
    "nl": "Buitenlicht Sensor",
    "de": "Außen Lichtsensor"
  },
  "class": "sensor",
  "capabilities": [
    "measure_luminance",
    "measure_battery"
  ],
  "capabilitiesOptions": {
    "measure_luminance": {
      "title": {
        "en": "Luminance",
        "fr": "Luminosité"
      }
    }
  },
  "zigbee": {
    "manufacturerName": [
      "_TZ3210_SNZBBGVI",
      "_tz3210_snzbbgvi"
    ],
    "productId": [
      "TS0222",
      "TS0601",
      "ts0222",
      "ts0601"
    ],
    "endpoints": {
      "1": {
        "clusters": [
          0,
          6
        ]
      }
    }
  },
  "images": {
    "small": "drivers/light_sensor_outdoor/assets/images/small.png",
    "large": "drivers/light_sensor_outdoor/assets/images/large.png",
    "xlarge": "drivers/light_sensor_outdoor/assets/images/xlarge.png"
  },
  "platforms": [
    "local"
  ],
  "connectivity": [
    "zigbee"
  ],
  "energy": {
    "batteries": [
      "CR2450"
    ],
    "mains": true
  },
  "maintenanceActions": [
    {
      "id": "ota_check",
      "title": {
        "en": "Check Zigbee OTA Update",
        "fr": "Vérifier MàJ OTA",
        "nl": "Controleer op OTA-updates"
      }
    }
  ],
  "flow": {
    "triggers": [
      {
        "id": "radio_presence_detected",
        "title": {
          "en": "Radio sensing presence detected",
          "fr": "Présence détectée par radio (LQI)"
        }
      }
    ],
    "conditions": [
      {
        "id": "is_radio_presence_detected",
        "title": {
          "en": "Radio presence is detected",
          "fr": "Présence radio détectée"
        }
      }
    ],
    "actions": [
      {
        "id": "calibrate_virtual_energy",
        "title": {
          "en": "Calibrate virtual energy",
          "fr": "Calibrer l'énergie virtuelle"
        },
        "args": [
          {
            "name": "watts",
            "type": "number",
            "placeholder": {
              "en": "Nominal Watts",
              "fr": "Watts nominaux"
            }
          }
        ]
      },
      {
        "id": "set_sensing_threshold",
        "title": {
          "en": "Set radio sensing sensitivity",
          "fr": "Régler la détection radio"
        },
        "args": [
          {
            "name": "threshold",
            "type": "number",
            "placeholder": "2-50"
          }
        ]
      }
    ]
  }
}