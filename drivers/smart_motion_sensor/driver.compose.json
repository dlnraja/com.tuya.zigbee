{
  "id": "smart_motion_sensor",
  "name": {
    "en": "Smart Motion Sensor (Lidl)"
  },
  "class": "sensor",
  "platforms": [
    "local"
  ],
  "connectivity": [
    "zigbee"
  ],
  "capabilities": [
    "measure_battery",
    "alarm_motion",
    "alarm_battery",
    "alarm_tamper",
    "button.1"
  ],
  "energy": {
    "batteries": [
      "CR123A"
    ]
  },
  "images": {
    "large": "/{{driverAssetsPath}}/images/large.png",
    "small": "/{{driverAssetsPath}}/images/small.png"
  },
  "zigbee": {
    "manufacturerName": [],
    "productId": [
      "TY0202"
    ],
    "endpoints": {
      "1": {
        "clusters": [
          0,
          1,
          1280
        ],
        "bindings": [
          1,
          1280
        ]
      }
    },
    "learnmode": {
      "image": "{{driverAssetsPath}}/icon.svg",
      "instruction": {
        "en": "Insert a pin into the single hole on the side of the device and press it gently for aprox 5 seconds until the LED blinks rapidly. If the pairing does not start, press the setup button again for 10-15 seconds until the led stops blinking and then try again."
      }
    }
  },
  "version": "1.0.0",
  "capabilitiesOptions": {
    "button.1": {
      "title": {
        "en": "Button 1",
        "fr": "Bouton 1"
      },
      "maintenanceAction": true,
      "getable": false,
      "setable": false
    }
  }
}
