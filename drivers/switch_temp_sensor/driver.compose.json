    "manufacturerName": [
      "_TZ3218_7FIYO3KV",
      "_tz3218_7fiyo3kv"
    ],
    "productId": [
      "TS0601_TEMPSWITCH",
      "TS0601_tempswitch",
      "ts0601_tempswitch"
    ],
    "endpoints": {
      "1": {
        "clusters": [
          0,
          61184
        ]
      }
    },
