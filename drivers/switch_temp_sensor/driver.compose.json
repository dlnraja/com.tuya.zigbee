        "en": "Temperature",
        "nl": "Temperatuur",
        "de": "Temperatur",
        "fr": "Température"
      }
    },
    "measure_humidity": {
      "title": {
        "en": "Humidity",
        "nl": "Luchtvochtigheid",
        "de": "Luftfeuchtigkeit",
        "fr": "Humidité"
      }
