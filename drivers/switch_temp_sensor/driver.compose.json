      "instruction": {
        "en": "Toggle the switch 5 times quickly (within 5 seconds) until the LED flashes rapidly, then release.",
        "nl": "Schakel 5 keer snel (binnen 5 seconden) totdat de LED snel knippert.",
        "de": "Schalten Sie 5 mal schnell (innerhalb von 5 Sekunden) bis die LED schnell blinkt.",
        "fr": "Basculez l'interrupteur 5 fois rapidement (en 5 secondes) jusqu'à ce que la LED clignote rapidement."
      }
    }
  },
  "images": {
    "small": "drivers/switch_temp_sensor/assets/images/small.png",
    "large": "drivers/switch_temp_sensor/assets/images/large.png",
    "xlarge": "drivers/switch_temp_sensor/assets/images/xlarge.png"
  },
  "maintenanceActions": [
    {
      "id": "ota_check",
      "title": {
        "en": "Check Zigbee OTA Update",
        "fr": "Vérifier MàJ OTA",
        "nl": "Controleer op OTA-updates"
      }
    }
  ],
  "flow": {
    "triggers": [
      {
        "id": "radio_presence_detected",
        "title": {
          "en": "Radio sensing presence detected",
          "fr": "Présence détectée par radio (LQI)"
        }
      }
    ],
    "conditions": [
      {
        "id": "is_radio_presence_detected",
        "title": {
          "en": "Radio presence is detected",
          "fr": "Présence radio détectée"
        }
      }
    ],
    "actions": [
      {
        "id": "calibrate_virtual_energy",
        "title": {
          "en": "Calibrate virtual energy",
          "fr": "Calibrer l'énergie virtuelle"
        },
        "args": [
          {
            "name": "watts",
            "type": "number",
            "placeholder": {
              "en": "Nominal Watts",
              "fr": "Watts nominaux"
            }
          }
        ]
      },
      {
        "id": "set_sensing_threshold",
        "title": {
          "en": "Set radio sensing sensitivity",
          "fr": "Régler la détection radio"
        },
        "args": [
          {
            "name": "threshold",
            "type": "number",
            "placeholder": "2-50"
          }
        ]
      }
    ]
