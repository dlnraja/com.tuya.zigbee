{
  "name": {
    "en": "LED Controller RGB",
    "fr": "Contrôleur LED RGB",
    "nl": "RGB LED Controller",
    "de": "RGB LED Steuerung"
  },
  "class": "light",
  "capabilities": [
    "onoff",
    "dim",
    "light_hue",
    "light_saturation",
    "light_temperature",
    "light_mode",
    "measure_battery"
  ],
  "zigbee": {
    "manufacturerName": [
      "_TZ3210_IYSTCADI",
      "_tz3210_iystcadi"
    ],
    "productId": [
      "TS0503",
      "TS0504",
      "ts0503",
      "ts0504"
    ],
    "endpoints": {
      "1": {
        "clusters": [
          0,
          3,
          4,
          5,
          6,
          8,
          768
        ]
      }
    }
  },
  "images": {
    "small": "drivers/led_controller_rgb/assets/images/small.png",
    "large": "drivers/led_controller_rgb/assets/images/large.png",
    "xlarge": "drivers/led_controller_rgb/assets/images/xlarge.png"
  },
  "platforms": [
    "local"
  ],
  "connectivity": [
    "zigbee"
  ],
  "energy": {
    "batteries": [
      "CR2450"
    ],
    "mains": true
  },
  "capabilitiesOptions": {
    "onoff": {
      "setOnDim": true
    }
  },
  "maintenanceActions": [
    {
      "id": "ota_check",
      "title": {
        "en": "Check Zigbee OTA Update",
        "fr": "Vérifier MàJ OTA",
        "nl": "Controleer op OTA-updates"
      }
    }
  ],
  "flow": {
    "triggers": [
      {
        "id": "radio_presence_detected",
        "title": {
          "en": "Radio sensing presence detected",
          "fr": "Présence détectée par radio (LQI)"
        }
      }
    ],
    "conditions": [
      {
        "id": "is_radio_presence_detected",
        "title": {
          "en": "Radio presence is detected",
          "fr": "Présence radio détectée"
        }
      }
    ],
    "actions": [
      {
        "id": "calibrate_virtual_energy",
        "title": {
          "en": "Calibrate virtual energy",
          "fr": "Calibrer l'énergie virtuelle"
        },
        "args": [
          {
            "name": "watts",
            "type": "number",
            "placeholder": {
              "en": "Nominal Watts",
              "fr": "Watts nominaux"
            }
          }
        ]
      },
      {
        "id": "set_sensing_threshold",
        "title": {
          "en": "Set radio sensing sensitivity",
          "fr": "Régler la détection radio"
        },
        "args": [
          {
            "name": "threshold",
            "type": "number",
            "placeholder": "2-50"
          }
        ]
      }
    ]
  }
}