    "da": "DIN-skinne Energimåler"
  },
  "class": "sensor",
  "energy": {
    "cumulative": true,
    "cumulativeImportedCapability": "meter_power",
    "cumulativeExportedCapability": "meter_power.exported"
  },
  "capabilities": [
    "measure_power",
    "meter_power",
    "measure_voltage",
    "measure_current",
    "meter_power.exported",
    "measure_radio_stability",
    "measure_maintenance_score"
  ],
  "capabilitiesOptions": {
    "measure_power": {
      "title": {
        "en": "Power",
        "fr": "Puissance"
      },
      "units": "W"
    },
    "meter_power": {
      "title": {
        "en": "Energy Consumed",
        "fr": "Énergie Consommée"
      },
      "units": "kWh"
    },
    "meter_power.exported": {
      "title": {
        "en": "Energy Exported",
        "fr": "Énergie Exportée"
      },
      "units": "kWh"
