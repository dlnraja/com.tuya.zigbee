{
  "name": {
    "en": "HVAC Controller",
    "fr": "Contrôleur HVAC",
    "nl": "HVAC Controller",
    "de": "HVAC Steuerung"
  },
  "class": "thermostat",
  "capabilities": [
    "onoff",
    "target_temperature",
    "measure_temperature",
    "thermostat_mode"
  ],
  "capabilitiesOptions": {
    "target_temperature": {
      "min": 16,
      "max": 30,
      "step": 0.5
    },
    "thermostat_mode": {
      "values": [
        {
          "id": "auto",
          "title": {
            "en": "Auto"
          }
        },
        {
          "id": "cool",
          "title": {
            "en": "Cool"
          }
        },
        {
          "id": "heat",
          "title": {
            "en": "Heat"
          }
        },
        {
          "id": "off",
          "title": {
            "en": "Off"
          }
        }
      ]
    }
  },
  "zigbee": {
    "manufacturerName": [
      "_TZE200_CFCZGBSS",
      "_TZE200_R32CTEZX",
      "_TZE204_R32CTEZX",
      "_TZE284_CFCZGBSS",
      "_tze200_cfczgbss",
      "_tze200_r32ctezx",
      "_tze204_r32ctezx",
      "_tze284_cfczgbss"
    ],
    "productId": [
      "TS0601",
      "ts0601"
    ],
    "endpoints": {
      "1": {
        "clusters": [
          0,
          6
        ]
      }
    }
  },
  "images": {
    "small": "drivers/hvac_controller/assets/images/small.png",
    "large": "drivers/hvac_controller/assets/images/large.png",
    "xlarge": "drivers/hvac_controller/assets/images/xlarge.png"
  },
  "platforms": [
    "local"
  ],
  "connectivity": [
    "zigbee"
  ],
  "energy": {
    "approximation": {
      "usageConstant": 5
    }
  },
  "maintenanceActions": [
    {
      "id": "ota_check",
      "title": {
        "en": "Check Zigbee OTA Update",
        "fr": "Vérifier MàJ OTA",
        "nl": "Controleer op OTA-updates"
      }
    }
  ],
  "flow": {
    "triggers": [
      {
        "id": "radio_presence_detected",
        "title": {
          "en": "Radio sensing presence detected",
          "fr": "Présence détectée par radio (LQI)"
        }
      }
    ],
    "conditions": [
      {
        "id": "is_radio_presence_detected",
        "title": {
          "en": "Radio presence is detected",
          "fr": "Présence radio détectée"
        }
      }
    ],
    "actions": [
      {
        "id": "calibrate_virtual_energy",
        "title": {
          "en": "Calibrate virtual energy",
          "fr": "Calibrer l'énergie virtuelle"
        },
        "args": [
          {
            "name": "watts",
            "type": "number",
            "placeholder": {
              "en": "Nominal Watts",
              "fr": "Watts nominaux"
            }
          }
        ]
      },
      {
        "id": "set_sensing_threshold",
        "title": {
          "en": "Set radio sensing sensitivity",
          "fr": "Régler la détection radio"
        },
        "args": [
          {
            "name": "threshold",
            "type": "number",
            "placeholder": "2-50"
          }
        ]
      }
    ]
  }
}