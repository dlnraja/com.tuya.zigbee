{
  "name": {
    "en": "Ceiling Presence Sensor (230V)",
    "fr": "Capteur de Présence Plafond (230V)",
    "nl": "Plafond Aanwezigheidssensor (230V)",
    "de": "Decken-Präsenzsensor (230V)"
  },
  "class": "sensor",
  "capabilities": [
    "alarm_motion",
    "onoff",
    "measure_luminance",
    "measure_luminance.distance",
    "measure_radio_stability",
    "measure_maintenance_score"
  ],
  "capabilitiesOptions": {
    "onoff": {
      "title": {
        "en": "Relay",
        "fr": "Relais",
        "nl": "Relais",
        "de": "Relais"
      },
      "insightsTitleTrue": {
        "en": "Relay turned on"
      },
      "insightsTitleFalse": {
        "en": "Relay turned off"
      }
    },
    "measure_luminance.distance": {
      "title": {
        "en": "Luminance distance"
      }
    }
  },
  "subDevices": [],
  "zigbee": {
    "manufacturerName": [
      "_TZE200_DTZZIY1E",
      "_TZE204_DTZZIY1E",
      "_TZE204_SBYX0LM6",
      "_TZE204_UXLLNYWP",
      "_TZE204_YENSYA2C",
      "_tze200_dtzziy1e",
      "_tze204_dtzziy1e",
      "_tze204_sbyx0lm6",
      "_tze204_uxllnywp",
      "_tze204_yensya2c"
    ],
    "productId": [
      "TS0601",
      "TS0601_CEILING",
      "TS0601_ceiling",
      "ts0601",
      "ts0601_ceiling"
    ],
    "endpoints": {
      "1": {
        "clusters": [
          0,
          61184
        ]
      }
    },
    "learnmode": {
      "image": "/drivers/presence_sensor_ceiling/assets/learnmode.svg",
      "instruction": {
        "en": "Press and hold the pairing button for 5 seconds until the LED flashes rapidly.",
        "fr": "Appuyez et maintenez le bouton d'appairage pendant 5 secondes jusqu'à ce que la LED clignote rapidement."
      }
    }
  },
  "settings": [
    {
      "type": "group",
      "label": {
        "en": "🎯 Radar Detection",
        "fr": "🎯 Détection Radar"
      },
      "children": [
        {
          "id": "radar_sensitivity",
          "type": "number",
          "label": {
            "en": "Radar Sensitivity",
            "fr": "Sensibilité Radar"
          },
          "value": 7,
          "min": 0,
          "max": 9,
          "step": 1,
          "hint": {
            "en": "Detection sensitivity (0=lowest, 9=highest).",
            "fr": "Sensibilité de détection (0=min, 9=max)."
          }
        },
        {
          "id": "minimum_range",
          "type": "number",
          "label": {
            "en": "Minimum Range (m)",
            "fr": "Distance Minimum (m)"
          },
          "value": 0,
          "min": 0,
          "max": 10,
          "step": 0.5,
          "hint": {
            "en": "Minimum detection distance. Objects closer will be ignored.",
            "fr": "Distance minimale de détection. Objets plus proches seront ignorés."
          }
        },
        {
          "id": "maximum_range",
          "type": "number",
          "label": {
            "en": "Maximum Range (m)",
            "fr": "Distance Maximum (m)"
          },
          "value": 6,
          "min": 0.5,
          "max": 10,
          "step": 0.5,
          "hint": {
            "en": "Maximum detection distance.",
            "fr": "Distance maximale de détection."
          }
        },
        {
          "id": "fading_time",
          "type": "number",
          "label": {
            "en": "Absence Delay (s)",
            "fr": "Délai d'Absence (s)"
          },
          "value": 60,
          "min": 1,
          "max": 1500,
          "step": 5,
          "hint": {
            "en": "Time before clearing presence after no movement.",
            "fr": "Temps avant de signaler l'absence."
          }
        }
      ]
    },
    {
      "type": "group",
      "label": {
        "en": "💡 Relay Control",
        "fr": "💡 Contrôle Relais"
      },
      "children": [
        {
          "id": "relay_mode",
          "type": "dropdown",
          "label": {
            "en": "Relay Mode",
            "fr": "Mode Relais"
          },
          "value": "auto",
          "values": [
            {
              "id": "auto",
              "label": {
                "en": "Auto (follows presence)",
                "fr": "Auto (suit la présence)"
              }
            },
            {
              "id": "manual",
              "label": {
                "en": "Manual (controlled via flows)",
                "fr": "Manuel (contrôlé via flows)"
              }
            },
            {
              "id": "always_on",
              "label": {
                "en": "Always On",
                "fr": "Toujours Allumé"
              }
            },
            {
              "id": "always_off",
              "label": {
                "en": "Always Off",
                "fr": "Toujours Éteint"
              }
            }
          ],
          "hint": {
            "en": "Control how the relay responds to presence detection.",
            "fr": "Contrôler la réponse du relais à la détection de présence."
          }
        },
        {
          "id": "relay_delay_on",
          "type": "number",
          "label": {
            "en": "Relay On Delay (s)",
            "fr": "Délai Activation Relais (s)"
          },
          "value": 0,
          "min": 0,
          "max": 60,
          "step": 1,
          "hint": {
            "en": "Delay before turning relay on after presence detected.",
            "fr": "Délai avant d'activer le relais après détection."
          }
        },
        {
          "id": "relay_delay_off",
          "type": "number",
          "label": {
            "en": "Relay Off Delay (s)",
            "fr": "Délai Désactivation Relais (s)"
          },
          "value": 0,
          "min": 0,
          "max": 300,
          "step": 5,
          "hint": {
            "en": "Delay before turning relay off after presence cleared.",
            "fr": "Délai avant de désactiver le relais après absence."
          }
        }
      ]
    },
    {
      "type": "group",
      "label": {
        "en": "🌡️ Calibration",
        "fr": "🌡️ Calibration"
      },
      "children": [
        {
          "id": "illuminance_calibration",
          "type": "number",
          "label": {
            "en": "Illuminance Offset (lux)",
            "fr": "Décalage Luminosité (lux)"
          },
          "value": 0,
          "min": -100,
          "max": 100,
          "step": 5,
          "hint": {
            "en": "Adjust illuminance reading.",
            "fr": "Ajuster la lecture de luminosité."
          }
        }
      ]
    },
    {
      "id": "enable_software_child_lock",
      "type": "checkbox",
      "label": {
        "en": "Software Child Lock",
        "fr": "Sécurité Enfant Logicielle"
      },
      "value": false,
      "hint": {
        "en": "Prevents manual state changes on the device",
        "fr": "Empêche les changements d'état manuels sur l'appareil"
      }
    },
    {
      "id": "auto_off_duration",
      "type": "number",
      "label": {
        "en": "Auto-Off Timer (Minutes)",
        "fr": "Minuterie Auto-Off (Minutes)"
      },
      "value": 0,
      "min": 0,
      "max": 1440,
      "hint": {
        "en": "Turn off automatically after X minutes (0 = disabled)",
        "fr": "S'éteint après X minutes (0 = désactivé)"
      }
    },
    {
      "id": "enable_vacation_mode",
      "type": "checkbox",
      "label": {
        "en": "Vacation Mode (Presence Sim)",
        "fr": "Mode Vacances (Simulation Présence)"
      },
      "value": false,
      "hint": {
        "en": "Randomly toggle device during evenings to simulate presence",
        "fr": "Actionne l'appareil aléatoirement le soir pour simuler une présence"
      }
    },
    {
      "id": "emulated_motion_hold",
      "type": "number",
      "label": {
        "en": "Emulated Motion Hold (Seconds)",
        "fr": "Maintien Mouvement Émulé (Secondes)"
      },
      "value": 0,
      "min": 0,
      "max": 3600,
      "hint": {
        "en": "Keep motion 'ON' for X seconds after hardware clears",
        "fr": "Garde le mouvement 'ON' pendant X secondes après le reset matériel"
      }
    },
    {
      "id": "double_click_interval",
      "type": "number",
      "label": {
        "en": "Double Click Interval (ms)",
        "fr": "Intervalle Double-Clic (ms)"
      },
      "value": 400,
      "min": 100,
      "max": 1000,
      "hint": {
        "en": "Software emulation for single-action buttons",
        "fr": "Émulation logicielle pour boutons à action unique"
      }
    }
  ],
  "images": {
    "small": "drivers/presence_sensor_ceiling/assets/images/small.png",
    "large": "drivers/presence_sensor_ceiling/assets/images/large.png",
    "xlarge": "drivers/presence_sensor_ceiling/assets/images/xlarge.png"
  },
  "platforms": [
    "local"
  ],
  "connectivity": [
    "zigbee"
  ],
  "pair": [
    {
      "id": "list_devices",
      "template": "list_devices",
      "navigation": {
        "next": "add_devices"
      }
    },
    {
      "id": "add_devices",
      "template": "add_devices"
    }
  ],
  "energy": {
    "approximation": {
      "usageConstant": 1
    }
  },
  "maintenanceActions": [
    {
      "id": "ota_check",
      "title": {
        "en": "Check Zigbee OTA Update",
        "fr": "Vérifier MàJ OTA",
        "nl": "Controleer op OTA-updates"
      }
    }
  ],
  "flow": {
    "triggers": [
      {
        "id": "radio_presence_detected",
        "title": {
          "en": "Radio sensing presence detected",
          "fr": "Présence détectée par radio (LQI)"
        }
      }
    ],
    "conditions": [
      {
        "id": "is_radio_presence_detected",
        "title": {
          "en": "Radio presence is detected",
          "fr": "Présence radio détectée"
        }
      }
    ],
    "actions": [
      {
        "id": "calibrate_virtual_energy",
        "title": {
          "en": "Calibrate virtual energy",
          "fr": "Calibrer l'énergie virtuelle"
        },
        "args": [
          {
            "name": "watts",
            "type": "number",
            "placeholder": {
              "en": "Nominal Watts",
              "fr": "Watts nominaux"
            }
          }
        ]
      },
      {
        "id": "set_sensing_threshold",
        "title": {
          "en": "Set radio sensing sensitivity",
          "fr": "Régler la détection radio"
        },
        "args": [
          {
            "name": "threshold",
            "type": "number",
            "placeholder": "2-50"
          }
        ]
      }
    ]
  }
}