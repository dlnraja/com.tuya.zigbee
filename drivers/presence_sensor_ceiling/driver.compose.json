  "settings": [
    {
      "type": "group",
      "label": {
        "en": "🎯 Radar Detection",
        "fr": "🎯 Détection Radar"
      },
      "children": [
        {
          "id": "radar_sensitivity",
          "type": "number",
          "label": {
            "en": "Radar Sensitivity",
            "fr": "Sensibilité Radar"
          },
          "value": 7,
          "min": 0,
          "max": 9,
          "step": 1,
          "hint": {
            "en": "Detection sensitivity (0=lowest, 9=highest).",
            "fr": "Sensibilité de détection (0=min, 9=max)."
          }
        },
        {
          "id": "minimum_range",
          "type": "number",
          "label": {
            "en": "Minimum Range (m)",
            "fr": "Distance Minimum (m)"
          },
          "value": 0,
          "min": 0,
          "max": 10,
          "step": 0.5,
          "hint": {
            "en": "Minimum detection distance. Objects closer will be ignored.",
            "fr": "Distance minimale de détection. Objets plus proches seront ignorés."
          }
        },
        {
          "id": "maximum_range",
          "type": "number",
          "label": {
            "en": "Maximum Range (m)",
            "fr": "Distance Maximum (m)"
          },
          "value": 6,
          "min": 0.5,
          "max": 10,
          "step": 0.5,
          "hint": {
            "en": "Maximum detection distance.",
            "fr": "Distance maximale de détection."
          }
        },
        {
          "id": "fading_time",
          "type": "number",
          "label": {
            "en": "Absence Delay (s)",
            "fr": "Délai d'Absence (s)"
          },
          "value": 60,
          "min": 1,
          "max": 1500,
          "step": 5,
          "hint": {
            "en": "Time before clearing presence after no movement.",
            "fr": "Temps avant de signaler l'absence."
          }
        }
      ]
    },
