          "en": "Gang 1 scene trigger",
          "fr": "Déclencheur de scène Gang 1"
        },
        "args": [
          {
            "name": "action",
            "type": "dropdown",
            "values": [
              {
                "id": "on",
                "label": {
                  "en": "On",
                  "fr": "On"
                }
              },
              {
                "id": "off",
                "label": {
                  "en": "Off",
                  "fr": "Off"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "wifi_switch_3gang_gang2_scene",
        "title": {
          "en": "Gang 2 scene trigger",
          "fr": "Déclencheur de scène Gang 2"
        },
        "args": [
          {
            "name": "action",
            "type": "dropdown",
            "values": [
              {
                "id": "on",
                "label": {
                  "en": "On",
                  "fr": "On"
                }
              },
              {
                "id": "off",
                "label": {
                  "en": "Off",
                  "fr": "Off"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "wifi_switch_3gang_gang3_scene",
        "title": {
          "en": "Gang 3 scene trigger",
          "fr": "Déclencheur de scène Gang 3"
        },
        "args": [
          {
            "name": "action",
            "type": "dropdown",
            "values": [
              {
                "id": "on",
                "label": {
                  "en": "On",
                  "fr": "On"
                }
              },
              {
                "id": "off",
                "label": {
