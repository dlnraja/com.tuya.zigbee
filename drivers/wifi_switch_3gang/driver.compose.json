{
  "name": {
    "en": "WiFi 3-Gang Switch"
  },
  "class": "socket",
  "capabilities": [
    "onoff",
    "onoff.gang2",
    "onoff.gang3"
  ],
  "pair": [
    {
      "id": "configure",
      "navigation": {
        "next": "list_devices"
      }
    },
    {
      "id": "list_devices",
      "template": "list_devices",
      "navigation": {
        "prev": "configure"
      }
    },
    {
      "id": "add_devices",
      "template": "add_devices"
    }
  ],
  "repair": [
    {
      "id": "configure"
    }
  ],
  "settings": [
    {
      "type": "group",
      "label": {
        "en": "Tuya Local"
      },
      "children": [
        {
          "id": "device_id",
          "type": "text",
          "label": {
            "en": "Device ID"
          },
          "value": ""
        },
        {
          "id": "local_key",
          "type": "text",
          "label": {
            "en": "Local Key"
          },
          "value": ""
        },
        {
          "id": "ip",
          "type": "text",
          "label": {
            "en": "IP"
          },
          "value": ""
        },
        {
          "id": "protocol_version",
          "type": "dropdown",
          "label": {
            "en": "Protocol"
          },
          "value": "3.3",
          "values": [
            {
              "id": "3.1",
              "label": {
                "en": "3.1"
              }
            },
            {
              "id": "3.3",
              "label": {
                "en": "3.3"
              }
            },
            {
              "id": "3.4",
              "label": {
                "en": "3.4"
              }
            },
            {
              "id": "3.5",
              "label": {
                "en": "3.5"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "sync_email",
      "type": "text",
      "label": {
        "en": "Cloud Sync Email",
        "fr": "Email de synchronisation"
      },
      "hint": {
        "en": "Optional: Email for automatic local key retrieval",
        "fr": "Optionnel : Email pour récupération auto des clés"
      }
    },
    {
      "id": "sync_password",
      "type": "password",
      "label": {
        "en": "Cloud Sync Password",
        "fr": "Mot de passe de synchronisation"
      },
      "hint": {
        "en": "Optional: Password for the Tuya/Smart Life app",
        "fr": "Optionnel : Mot de passe de l'app Tuya/Smart Life"
      }
    }
  ],
  "images": {
    "small": "drivers/wifi_switch_3gang/assets/images/small.png",
    "large": "drivers/wifi_switch_3gang/assets/images/large.png",
    "xlarge": "drivers/wifi_switch_3gang/assets/images/xlarge.png"
  },
  "platforms": [
    "local"
  ],
  "connectivity": [
    "lan"
  ],
  "capabilitiesOptions": {
    "onoff": {
      "title": {
        "en": "S1"
      }
    },
    "onoff.gang2": {
      "title": {
        "en": "S2"
      }
    },
    "onoff.gang3": {
      "title": {
        "en": "S3"
      }
    }
  },
  "maintenanceActions": [
    {
      "id": "ota_check",
      "title": {
        "en": "Check Zigbee OTA Update",
        "fr": "Vérifier MàJ OTA",
        "nl": "Controleer op OTA-updates"
      }
    }
  ],
  "discoveryStrategies": [
    {
      "strategy": "mdns-sd",
      "options": {
        "name": "_tuya._tcp.local"
      }
    },
    {
      "strategy": "ssdp",
      "options": {
        "search": "urn:schemas-upnp-org:device:Basic:1"
      }
    }
  ],
  "flow": {
    "triggers": [
      {
        "id": "wifi_switch_3gang_physical_gang1_on",
        "title": {
          "en": "Gang 1 turned on (physical)",
          "fr": "Gang 1 allumé (physique)"
        }
      },
      {
        "id": "wifi_switch_3gang_physical_gang1_off",
        "title": {
          "en": "Gang 1 turned off (physical)",
          "fr": "Gang 1 allumé (éteint) (physique)"
        }
      },
      {
        "id": "wifi_switch_3gang_physical_gang2_on",
        "title": {
          "en": "Gang 2 turned on (physical)",
          "fr": "Gang 2 allumé (physique)"
        }
      },
      {
        "id": "wifi_switch_3gang_physical_gang2_off",
        "title": {
          "en": "Gang 2 turned off (physical)",
          "fr": "Gang 2 allumé (éteint) (physique)"
        }
      },
      {
        "id": "wifi_switch_3gang_physical_gang3_on",
        "title": {
          "en": "Gang 3 turned on (physical)",
          "fr": "Gang 3 allumé (physique)"
        }
      },
      {
        "id": "wifi_switch_3gang_physical_gang3_off",
        "title": {
          "en": "Gang 3 turned off (physical)",
          "fr": "Gang 3 allumé (éteint) (physique)"
        }
      },
      {
        "id": "wifi_switch_3gang_gang1_scene",
