      "id": "wall_switch_3gang_1way_set_backlight",
      "title": {
        "en": "Set LED indicator mode",
        "nl": "Stel LED-indicator modus in"
      },
      "titleFormatted": {
        "en": "[[device]] set LED indicator to [[mode]]",
        "nl": "[[device]] stel LED-indicator in op [[mode]]"
      },
      "args": [
        {
          "type": "device",
          "name": "device",
          "filter": "driver_id=wall_switch_3gang_1way"
        },
        {
          "name": "mode",
          "type": "dropdown",
          "values": [
            {
              "id": "off",
              "label": {
                "en": "Always Off",
                "nl": "Altijd Uit"
              }
            },
            {
              "id": "normal",
              "label": {
                "en": "On when Switch ON",
                "nl": "Aan bij AAN"
              }
            },
            {
              "id": "inverted",
              "label": {
                "en": "On when Switch OFF",
                "nl": "Aan bij UIT"
              }
            }
          ]
        }
      ]
    },
    {
