  "settings": [
    {
      "type": "group",
      "label": {
        "en": "Radiator Configuration",
        "fr": "Configuration Radiateur"
      },
      "children": [
        {
          "id": "pilot_wire_type",
          "type": "dropdown",
          "label": {
            "en": "Pilot Wire Type",
            "fr": "Type Fil Pilote"
          },
          "hint": {
            "en": "Select the type of pilot wire system used by your electric radiator",
            "fr": "Sélectionnez le type de système fil pilote de votre radiateur électrique"
          },
          "value": "standard_6_orders",
          "values": [
            {
              "id": "standard_6_orders",
              "label": {
                "en": "🔥 Standard 6 Orders (Confort/Eco/Hors-Gel/Arrêt/Confort-1/Confort-2)",
                "fr": "🔥 Standard 6 Ordres (Confort/Eco/Hors-Gel/Arrêt/Confort-1/Confort-2)"
              }
            },
            {
              "id": "standard_4_orders",
              "label": {
                "en": "⚡ Standard 4 Orders (Confort/Eco/Hors-Gel/Arrêt)",
                "fr": "⚡ Standard 4 Ordres (Confort/Eco/Hors-Gel/Arrêt)"
              }
            },
            {
              "id": "simple_on_off",
              "label": {
                "en": "🔌 Simple ON/OFF",
                "fr": "🔌 Simple MARCHE/ARRÊT"
              }
            }
          ]
        },
        {
          "id": "diode_type",
          "type": "dropdown",
          "label": {
            "en": "Diode Configuration",
            "fr": "Configuration Diode"
          },
          "hint": {
            "en": "Hardware diode setup for pilot wire control (1N4007 recommended)",
            "fr": "Configuration matérielle diode pour contrôle fil pilote (1N4007 recommandée)"
          },
          "value": "single_1n4007",
          "values": [
            {
              "id": "single_1n4007",
              "label": {
                "en": "🔴 Single 1N4007 (Mono-directional)",
                "fr": "🔴 Simple 1N4007 (Mono-directionnel)"
              }
            },
            {
              "id": "dual_1n4007",
              "label": {
                "en": "🔴🔴 Dual 1N4007 (Bi-directional)",
                "fr": "🔴🔴 Double 1N4007 (Bi-directionnel)"
              }
            },
            {
              "id": "none",
              "label": {
                "en": "⚪ No Diode (Direct connection)",
                "fr": "⚪ Pas de Diode (Connexion directe)"
              }
            }
          ]
        },
        {
          "id": "heating_mode",
          "type": "dropdown",
          "label": {
            "en": "Default Heating Mode",
            "fr": "Mode Chauffage par Défaut"
          },
          "value": "confort",
          "values": [
            {
              "id": "confort",
              "label": {
                "en": "🏠 Confort (100%)",
                "fr": "🏠 Confort (100%)"
              }
            },
            {
              "id": "eco",
              "label": {
                "en": "🌱 Éco (-3°C/4°C)",
                "fr": "🌱 Éco (-3°C/4°C)"
              }
            },
            {
              "id": "confort_minus_1",
              "label": {
                "en": "🌡️ Confort -1°C",
                "fr": "🌡️ Confort -1°C"
              }
            },
            {
              "id": "confort_minus_2",
              "label": {
                "en": "❄️ Confort -2°C",
                "fr": "❄️ Confort -2°C"
              }
            },
            {
              "id": "anti_freeze",
              "label": {
                "en": "🧊 Hors-Gel (7°C)",
                "fr": "🧊 Hors-Gel (7°C)"
              }
            },
            {
              "id": "off",
              "label": {
                "en": "⛔ Arrêt",
                "fr": "⛔ Arrêt"
              }
            }
          ]
        },
        {
          "id": "enable_scheduling",
          "type": "checkbox",
          "label": {
            "en": "Enable Smart Scheduling",
            "fr": "Activer Programmation Intelligente"
          },
          "hint": {
            "en": "Allow automatic mode switching based on time and presence",
            "fr": "Permettre le changement automatique de mode selon l'heure et la présence"
          },
          "value": false
        },
        {
          "id": "disable_power_monitoring",
          "type": "checkbox",
          "label": {
            "en": "Disable Energy Monitoring",
            "fr": "Désactiver Surveillance Énergétique"
          },
          "hint": {
            "en": "Radiators with pilot wire don't provide accurate energy readings",
            "fr": "Les radiateurs avec fil pilote ne fournissent pas de mesures énergétiques précises"
          },
          "value": true
        }
      ]
    },
    {
      "type": "group",
      "label": {
        "en": "Advanced Settings",
        "fr": "Paramètres Avancés"
      },
      "children": [
        {
          "id": "signal_duration_ms",
          "type": "number",
          "label": {
            "en": "Signal Duration (ms)",
            "fr": "Durée Signal (ms)"
          },
          "hint": {
            "en": "Duration of pilot wire signal pulses (typically 500-2000ms)",
            "fr": "Durée des impulsions signal fil pilote (typiquement 500-2000ms)"
          },
          "value": 1000,
          "min": 100,
          "max": 5000,
          "step": 100
        },
        {
          "id": "signal_interval_s",
          "type": "number",
          "label": {
            "en": "Signal Interval (seconds)",
            "fr": "Intervalle Signal (secondes)"
          },
          "hint": {
            "en": "Time between pilot wire signals (typically 5-60 seconds)",
            "fr": "Temps entre les signaux fil pilote (typiquement 5-60 secondes)"
          },
          "value": 30,
          "min": 5,
          "max": 300,
          "step": 5
        },
        {
          "id": "override_thermostat",
          "type": "checkbox",
          "label": {
            "en": "Override Radiator Thermostat",
            "fr": "Forcer Thermostat Radiateur"
          },
          "hint": {
            "en": "Force radiator to ignore its internal thermostat (advanced users only)",
            "fr": "Forcer le radiateur à ignorer son thermostat interne (utilisateurs avancés uniquement)"
          },
          "value": false
        },
        {
          "id": "debug_logging",
          "type": "checkbox",
          "label": {
            "en": "Enable Debug Logging",
            "fr": "Activer Logs Debug"
          },
          "hint": {
            "en": "Log detailed pilot wire signals for troubleshooting",
            "fr": "Enregistrer les signaux fil pilote détaillés pour dépannage"
          },
          "value": false
        }
      ]
    }
