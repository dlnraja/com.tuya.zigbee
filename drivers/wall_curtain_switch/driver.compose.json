{
  "id": "wallcurtainswitch",
  "name": {
    "en": "Wall mounted Curtain Switch"
  },
  "class": "curtain",
  "platforms": [
    "local"
  ],
  "connectivity": [
    "zigbee"
  ],
  "capabilities": [
    "windowcoverings_set",
    "windowcoverings_state"
  ],
  "images": {
    "large": "drivers/wall_curtain_switch/assets/images/large.png",
    "small": "drivers/wall_curtain_switch/assets/images/small.png",
    "xlarge": "drivers/wall_curtain_switch/assets/images/xlarge.png"
  },
  "energy": {
    "approximation": {
      "usageOn": 0,
      "usageOff": 0
    }
  },
  "zigbee": {
    "manufacturerName": [
      "_TZ3000_WPTAYAQR",
      "_tz3000_wptayaqr"
    ],
    "productId": [],
    "endpoints": {
      "1": {
        "clusters": [
          0,
          4,
          5,
          258
        ]
      }
    },
    "learnmode": {
      "image": "{{driverAssetsPath}}/icon.svg",
      "instruction": {
        "en": "Power on/off 5 times to enter pairing mode (the LED should blink / device starts beeping) or press the Pause-button 5sec until Open-button blinks."
      }
    }
  },
  "maintenanceActions": [
    {
      "id": "ota_check",
      "title": {
        "en": "Check Zigbee OTA Update",
        "fr": "Vérifier MàJ OTA",
        "nl": "Controleer op OTA-updates"
      }
    }
  ],
  "flow": {
    "triggers": [
      {
        "id": "radio_presence_detected",
        "title": {
          "en": "Radio sensing presence detected",
          "fr": "Présence détectée par radio (LQI)"
        }
      }
    ],
    "conditions": [
      {
        "id": "is_radio_presence_detected",
        "title": {
          "en": "Radio presence is detected",
          "fr": "Présence radio détectée"
        }
      }
    ],
    "actions": [
      {
        "id": "calibrate_virtual_energy",
        "title": {
          "en": "Calibrate virtual energy",
          "fr": "Calibrer l'énergie virtuelle"
        },
        "args": [
          {
            "name": "watts",
            "type": "number",
            "placeholder": {
              "en": "Nominal Watts",
              "fr": "Watts nominaux"
            }
          }
        ]
      },
      {
        "id": "set_sensing_threshold",
        "title": {
          "en": "Set radio sensing sensitivity",
          "fr": "Régler la détection radio"
        },
        "args": [
          {
            "name": "threshold",
            "type": "number",
            "placeholder": "2-50"
          }
        ]
      }
    ]
  }
}