{
  "name": {
    "en": "Device Air Purifier Smart Hybrid",
    "nl": "Slimme hybride luchtzuiveraar",
    "fr": "Purificateur d'air intelligent hybride",
    "de": "Intelligenter Hybrid-Luftreiniger",
    "es": "Purificador de aire inteligente híbrido"
  },
  "class": "thermostat",
  "capabilities": [
    "target_temperature",
    "measure_temperature",
    "measure_humidity",
    "thermostat_mode",
    "onoff",
    "dim",
    "measure_pm25"
  ],
  "capabilitiesOptions": {
    "target_temperature": {
      "min": 5,
      "max": 35,
      "step": 0.5
    },
    "thermostat_mode": {
      "values": [
        {
          "id": "auto",
          "title": {
            "en": "Schedule"
          }
        },
        {
          "id": "heat",
          "title": {
            "en": "Manual"
          }
        },
        {
          "id": "off",
          "title": {
            "en": "Off"
          }
        }
      ]
    }
  },
  "zigbee": {
    "manufacturerName": [
      "_TZE200_KLY8GJLZ",
      "_tze200_kly8gjlz"
    ],
    "productId": [],
    "endpoints": {
      "1": {
        "clusters": [
          0,
          6
        ]
      }
    }
  },
  "images": {
    "small": "drivers/smart_lcd_thermostat/assets/images/small.png",
    "large": "drivers/smart_lcd_thermostat/assets/images/large.png",
    "xlarge": "drivers/smart_lcd_thermostat/assets/images/xlarge.png"
  },
  "platforms": [
    "local"
  ],
  "connectivity": [
    "zigbee"
  ],
  "energy": {
    "approximation": {
      "usageConstant": 1
    }
  },
  "maintenanceActions": [
    {
      "id": "ota_check",
      "title": {
        "en": "Check Zigbee OTA Update",
        "fr": "Vérifier MàJ OTA",
        "nl": "Controleer op OTA-updates"
      }
    }
  ],
  "flow": {
    "triggers": [
      {
        "id": "radio_presence_detected",
        "title": {
          "en": "Radio sensing presence detected",
          "fr": "Présence détectée par radio (LQI)"
        }
      }
    ],
    "conditions": [
      {
        "id": "is_radio_presence_detected",
        "title": {
          "en": "Radio presence is detected",
          "fr": "Présence radio détectée"
        }
      }
    ],
    "actions": [
      {
        "id": "calibrate_virtual_energy",
        "title": {
          "en": "Calibrate virtual energy",
          "fr": "Calibrer l'énergie virtuelle"
        },
        "args": [
          {
            "name": "watts",
            "type": "number",
            "placeholder": {
              "en": "Nominal Watts",
              "fr": "Watts nominaux"
            }
          }
        ]
      },
      {
        "id": "set_sensing_threshold",
        "title": {
          "en": "Set radio sensing sensitivity",
          "fr": "Régler la détection radio"
        },
        "args": [
          {
            "name": "threshold",
            "type": "number",
            "placeholder": "2-50"
          }
        ]
      }
    ]
  }
}