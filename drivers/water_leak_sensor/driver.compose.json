        "fr": "Déclencher l'alerte batterie faible en dessous de ce pourcentage"
      }
    },
    {
      "id": "battery_critical_threshold",
      "type": "number",
      "label": {
        "en": "Critical Battery Threshold",
        "fr": "Seuil Batterie Critique (%)"
