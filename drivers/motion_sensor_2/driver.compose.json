{
  "id": "motion_sensor_2",
  "name": {
    "en": "Motion Sensor",
    "fr": "Capteur de mouvement",
    "nl": "Bewegingssensor",
    "de": "Bewegungsmelder",
    "es": "Sensor de movimiento"
  },
  "class": "sensor",
  "platforms": [
    "local"
  ],
  "connectivity": [
    "zigbee"
  ],
  "capabilities": [
    "measure_battery",
    "measure_luminance",
    "alarm_motion"
  ],
  "energy": {
    "batteries": [
      "CR2450"
    ],
    "mains": true
  },
  "images": {
    "large": "{{driverAssetsPath}}/images/large.png",
    "small": "{{driverAssetsPath}}/images/small.png"
  },
  "zigbee": {
    "manufacturerName": [],
    "productId": [
      "TS0601",
      "ts0601"
    ],
    "endpoints": {
      "1": {
        "clusters": [
          0,
          61184
        ],
        "bindings": [
          1,
          1024,
          1280
        ]
      }
    },
    "learnmode": {
      "image": "{{driverAssetsPath}}/icon.svg",
      "instruction": {
        "en": "Press the reset button for aprox 5 seconds until the LED blinks."
      }
    }
  },
  "maintenanceActions": [
    {
      "id": "ota_check",
      "title": {
        "en": "Check Zigbee OTA Update",
        "fr": "Vérifier MàJ OTA",
        "nl": "Controleer op OTA-updates"
      }
    }
  ],
  "flow": {
    "triggers": [
      {
        "id": "radio_presence_detected",
        "title": {
          "en": "Radio sensing presence detected",
          "fr": "Présence détectée par radio (LQI)"
        }
      }
    ],
    "conditions": [
      {
        "id": "is_radio_presence_detected",
        "title": {
          "en": "Radio presence is detected",
          "fr": "Présence radio détectée"
        }
      }
    ],
    "actions": [
      {
        "id": "calibrate_virtual_energy",
        "title": {
          "en": "Calibrate virtual energy",
          "fr": "Calibrer l'énergie virtuelle"
        },
        "args": [
          {
            "name": "watts",
            "type": "number",
            "placeholder": {
              "en": "Nominal Watts",
              "fr": "Watts nominaux"
            }
          }
        ]
      },
      {
        "id": "set_sensing_threshold",
        "title": {
          "en": "Set radio sensing sensitivity",
          "fr": "Régler la détection radio"
        },
        "args": [
          {
            "name": "threshold",
            "type": "number",
            "placeholder": "2-50"
          }
        ]
      }
    ]
  }
}