      "value": 24,
      "min": 1,
      "max": 168,
      "step": 1,
      "hint": {
        "en": "How often to request battery status updates",
        "fr": "Fréquence de demande des mises à jour d'état de batterie"
      }
    },
    {
      "id": "optimization_mode",
      "type": "dropdown",
      "label": {
        "en": "Energy Optimization Mode",
        "fr": "Mode Optimisation Énergétique"
