{
  "name": {
    "en": "WiFi Device (Tuya Local)",
    "fr": "Appareil WiFi (Tuya Local)",
    "nl": "WiFi Apparaat (Tuya Lokaal)",
    "de": "WiFi Gerät (Tuya Lokal)"
  },
  "class": "other",
  "capabilities": [
    "onoff"
  ],
  "pair": [
    {
      "id": "configure",
      "navigation": {
        "next": "list_devices"
      }
    },
    {
      "id": "list_devices",
      "template": "list_devices",
      "navigation": {
        "prev": "configure"
      }
    },
    {
      "id": "add_devices",
      "template": "add_devices"
    }
  ],
  "repair": [
    {
      "id": "configure"
    }
  ],
  "settings": [
    {
      "type": "group",
      "label": {
        "en": "Tuya Local Connection"
      },
      "children": [
        {
          "id": "device_id",
          "type": "text",
          "label": {
            "en": "Device ID"
          },
          "hint": {
            "en": "Tuya device ID (from Tuya IoT platform)"
          },
          "value": ""
        },
        {
          "id": "local_key",
          "type": "text",
          "label": {
            "en": "Local Key"
          },
          "hint": {
            "en": "AES local key (from Tuya IoT platform)"
          },
          "value": ""
        },
        {
          "id": "ip",
          "type": "text",
          "label": {
            "en": "IP Address"
          },
          "hint": {
            "en": "Device LAN IP (optional)"
          },
          "value": ""
        },
        {
          "id": "protocol_version",
          "type": "dropdown",
          "label": {
            "en": "Protocol Version"
          },
          "value": "3.3",
          "values": [
            {
              "id": "3.1",
              "label": {
                "en": "3.1"
              }
            },
            {
              "id": "3.3",
              "label": {
                "en": "3.3 (most common)"
              }
            },
            {
              "id": "3.4",
              "label": {
                "en": "3.4"
              }
            },
            {
              "id": "3.5",
              "label": {
                "en": "3.5"
              }
            }
          ]
        },
        {
          "id": "discovered_dps",
          "type": "text",
          "label": {
            "en": "Discovered DPs (auto)"
          },
          "hint": {
            "en": "Raw data points received from device"
          },
          "value": ""
        }
      ]
    },
    {
      "id": "sync_email",
      "type": "text",
      "label": {
        "en": "Cloud Sync Email",
        "fr": "Email de synchronisation"
      },
      "hint": {
        "en": "Optional: Email for automatic local key retrieval",
        "fr": "Optionnel : Email pour récupération auto des clés"
      }
    },
    {
      "id": "sync_password",
      "type": "password",
      "label": {
        "en": "Cloud Sync Password",
        "fr": "Mot de passe de synchronisation"
      },
      "hint": {
        "en": "Optional: Password for the Tuya/Smart Life app",
        "fr": "Optionnel : Mot de passe de l'app Tuya/Smart Life"
      }
    }
  ],
  "images": {
    "small": "drivers/wifi_generic/assets/images/small.png",
    "large": "drivers/wifi_generic/assets/images/large.png",
    "xlarge": "drivers/wifi_generic/assets/images/xlarge.png"
  },
  "platforms": [
    "local"
  ],
  "connectivity": [
    "lan"
  ],
  "maintenanceActions": [
    {
      "id": "ota_check",
      "title": {
        "en": "Check Zigbee OTA Update",
        "fr": "Vérifier MàJ OTA",
        "nl": "Controleer op OTA-updates"
      }
    }
  ],
  "discoveryStrategies": [
    {
      "strategy": "mdns-sd",
      "options": {
        "name": "_tuya._tcp.local"
      }
    },
    {
      "strategy": "ssdp",
      "options": {
        "search": "urn:schemas-upnp-org:device:Basic:1"
      }
    }
  ]
}
