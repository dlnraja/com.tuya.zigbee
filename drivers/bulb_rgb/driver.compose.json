            "nl": "Uitgebreid (2000K-6500K)",
            "de": "Erweitert (2000K-6500K)",
            "fr": "Étendu (2000K-6500K)"
          }
        },
        {
          "id": "wide",
          "label": {
            "en": "Wide (1800K-6500K)",
            "nl": "Breed (1800K-6500K)",
            "de": "Breit (1800K-6500K)",
            "fr": "Large (1800K-6500K)"
          }
        }
      ],
      "hint": {
        "en": "Adjust color temperature range based on your bulb capabilities",
        "nl": "Pas kleurtemperatuurbereik aan op basis van lampcapaciteiten",
        "de": "Farbtemperaturbereich basierend auf Lampenfähigkeiten anpassen",
        "fr": "Ajuster la plage de température de couleur selon les capacités de l'ampoule"
      }
