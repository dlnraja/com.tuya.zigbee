{
  "name": {
    "en": "eWeLink TH Sensor Switch (SONOFF)"
  },
  "class": "socket",
  "capabilities": [
    "onoff",
    "measure_temperature",
    "measure_humidity"
  ],
  "pair": [
    {
      "id": "configure",
      "navigation": {
        "next": "list_devices"
      }
    },
    {
      "id": "list_devices",
      "template": "list_devices",
      "navigation": {
        "prev": "configure"
      }
    },
    {
      "id": "add_devices",
      "template": "add_devices"
    }
  ],
  "repair": [
    {
      "id": "configure"
    }
  ],
  "settings": [
    {
      "type": "group",
      "label": {
        "en": "eWeLink LAN"
      },
      "children": [
        {
          "id": "device_id",
          "type": "text",
          "label": {
            "en": "Device ID"
          },
          "value": ""
        },
        {
          "id": "api_key",
          "type": "text",
          "label": {
            "en": "API Key"
          },
          "value": ""
        },
        {
          "id": "ip",
          "type": "text",
          "label": {
            "en": "IP Address"
          },
          "value": ""
        },
        {
          "id": "encrypt",
          "type": "checkbox",
          "label": {
            "en": "Encrypted"
          },
          "value": true
        }
      ]
    },
    {
      "id": "sync_email",
      "type": "text",
      "label": {
        "en": "Cloud Sync Email",
        "fr": "Email de synchronisation"
      },
      "hint": {
        "en": "Optional: Email for automatic local key retrieval",
        "fr": "Optionnel : Email pour récupération auto des clés"
      }
    },
    {
      "id": "sync_password",
      "type": "password",
      "label": {
        "en": "Cloud Sync Password",
        "fr": "Mot de passe de synchronisation"
      },
      "hint": {
        "en": "Optional: Password for the Tuya/Smart Life app",
        "fr": "Optionnel : Mot de passe de l'app Tuya/Smart Life"
      }
    }
  ],
  "images": {
    "small": "drivers/wifi_ewelink_th/assets/images/small.png",
    "large": "drivers/wifi_ewelink_th/assets/images/large.png",
    "xlarge": "drivers/wifi_ewelink_th/assets/images/xlarge.png"
  },
  "platforms": [
    "local"
  ],
  "connectivity": [
    "lan"
  ],
  "discovery": "ewelink_mdns",
  "maintenanceActions": [
    {
      "id": "ota_check",
      "title": {
        "en": "Check Zigbee OTA Update",
        "fr": "Vérifier MàJ OTA",
        "nl": "Controleer op OTA-updates"
      }
    }
  ],
  "discoveryStrategies": [
    {
      "strategy": "mdns-sd",
      "options": {
        "name": "_tuya._tcp.local"
      }
    },
    {
      "strategy": "ssdp",
      "options": {
        "search": "urn:schemas-upnp-org:device:Basic:1"
      }
    }
  ]
}
