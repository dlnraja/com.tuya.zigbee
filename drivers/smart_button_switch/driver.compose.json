{
  "id": "smart_button_switch",
  "name": {
    "en": "Smart Button Switch"
  },
  "class": "remote",
  "platforms": [
    "local"
  ],
  "connectivity": [
    "zigbee"
  ],
  "capabilities": [
    "button.1",
    "measure_battery"
  ],
  "images": {
    "large": "drivers/smart_button_switch/assets/images/large.png",
    "small": "drivers/smart_button_switch/assets/images/small.png",
    "xlarge": "drivers/smart_button_switch/assets/images/xlarge.png"
  },
  "energy": {
    "batteries": [
      "CR2032"
    ]
  },
  "zigbee": {
    "manufacturerName": [],
    "productId": [
      "TS0041"
    ],
    "endpoints": {
      "1": {
        "clusters": [
          0,
          6
        ]
      }
    },
    "learnmode": {
      "image": "{{driverAssetsPath}}/icon.svg",
      "instruction": {
        "en": "Press the button for aprox 10 seconds (the LED should start blinking)."
      }
    }
  },
  "settings": [
    {
      "id": "button_mode",
      "type": "dropdown",
      "label": {
        "en": "Operating Mode",
        "fr": "Mode de fonctionnement"
      },
      "hint": {
        "en": "Scene Mode allows single/double/long press. Dimmer Mode only supports single press. Auto tries to detect and switch automatically.",
        "fr": "Le mode Scène permet les appuis simples/doubles/longs. Le mode Variateur ne supporte que l'appui simple. Auto tente de détecter et basculer automatiquement."
      },
      "value": "auto",
      "values": [
        {
          "id": "auto",
          "label": {
            "en": "Auto-Detect",
            "fr": "Détection Auto"
          }
        },
        {
          "id": "scene",
          "label": {
            "en": "Scene Mode (Multi-press)",
            "fr": "Mode Scène (Multi-clics)"
          }
        },
        {
          "id": "dimmer",
          "label": {
            "en": "Dimmer Mode",
            "fr": "Mode Variateur"
          }
        }
      ]
    }
  ],
  "maintenanceActions": [
    {
      "id": "ota_check",
      "title": {
        "en": "Check Zigbee OTA Update",
        "fr": "Vérifier MàJ OTA",
        "nl": "Controleer op OTA-updates"
      }
    }
  ],
  "capabilitiesOptions": {
    "button.1": {
      "title": {
        "en": "Button 1",
        "fr": "Bouton 1",
        "nl": "Knop 1",
        "de": "Taste 1"
      }
    },
    "measure_battery": {
      "title": {
        "en": "Battery",
        "fr": "Batterie",
        "nl": "Batterij",
        "de": "Batterie"
      }
    }
  }
}
