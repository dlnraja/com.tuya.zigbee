          "filter": "driver_id=switch_1gang"
        }
      ]
    },
    {
      "id": "switch_1gang_turned_off",
      "title": {
        "en": "Turned off",
        "fr": "Éteint",
        "nl": "Uitgezet",
        "de": "Ausgeschaltet"
      },
      "args": [
        {
          "name": "device",
          "type": "device",
          "filter": "driver_id=switch_1gang"
        }
      ]
    },
    {
      "id": "switch_1gang_physical_on",
      "title": {
        "en": "Physical ON",
        "fr": "Physique ON",
        "nl": "Fysiek AAN",
        "de": "Physisch EIN"
      },
      "args": [
        {
          "name": "device",
          "type": "device",
          "filter": "driver_id=switch_1gang"
        }
      ]
    },
    {
      "id": "switch_1gang_physical_off",
      "title": {
        "en": "Physical OFF",
        "fr": "Physique OFF",
        "nl": "Fysiek UIT",
        "de": "Physisch AUS"
      },
      "args": [
        {
          "name": "device",
          "type": "device",
          "filter": "driver_id=switch_1gang"
        }
      ]
    }
  ],
  "conditions": [
    {
      "id": "switch_1gang_is_on",
      "title": {
        "en": "Is !{{on|off}}",
        "fr": "Est !{{allumé|éteint}}",
        "nl": "Is !{{aan|uit}}",
        "de": "Ist !{{ein|aus}}"
      },
      "args": [
        {
          "name": "device",
          "type": "device",
          "filter": "driver_id=switch_1gang"
        }
      ]
    }
  ],
  "actions": [
    {
      "id": "switch_1gang_turn_on",
      "title": {
        "en": "Turn on",
        "fr": "Allumer",
        "nl": "Aanzetten",
        "de": "Einschalten"
      },
      "args": [
        {
          "name": "device",
          "type": "device",
          "filter": "driver_id=switch_1gang"
        }
      ]
    },
    {
      "id": "switch_1gang_turn_off",
      "title": {
        "en": "Turn off",
        "fr": "Éteindre",
        "nl": "Uitzetten",
        "de": "Ausschalten"
      },
      "args": [
        {
          "name": "device",
          "type": "device",
          "filter": "driver_id=switch_1gang"
        }
      ]
    },
    {
      "id": "switch_1gang_toggle",
      "title": {
        "en": "Toggle",
        "fr": "Basculer",
        "nl": "Wisselen",
        "de": "Umschalten"
      },
      "args": [
        {
          "name": "device",
          "type": "device",
          "filter": "driver_id=switch_1gang"
        }
      ]
    },
    {
      "id": "switch_1gang_set_backlight",
      "title": { "en": "Set backlight mode" },
      "args": [{ "name": "mode", "type": "dropdown", "values": [{ "id": "off", "label": "Off" }, { "id": "normal", "label": "Normal" }, { "id": "inverted", "label": "Inverted" }], "title": { "en": "Backlight mode" } }]
    },
    {
      "id": "switch_1gang_set_backlight_color",
      "title": { "en": "Set backlight color" },
      "args": [{ "name": "color", "type": "dropdown", "values": [{ "id": "white", "label": "White" }, { "id": "red", "label": "Red" }, { "id": "blue", "label": "Blue" }, { "id": "green", "label": "Green" }], "title": { "en": "Backlight color" } }]
    },
    {
      "id": "switch_1gang_set_backlight_brightness",
      "title": { "en": "Set backlight brightness" },
      "args": [{ "name": "brightness", "type": "range", "min": 0, "max": 100, "step": 1, "label": "%", "title": { "en": "Brightness" } }]
    },
    {
      "id": "switch_1gang_set_countdown",
      "title": { "en": "Set countdown timer" },
      "args": [{ "name": "seconds", "type": "number", "title": { "en": "Countdown (seconds)" } }]
    },
    {
      "id": "switch_1gang_set_child_lock",
      "title": { "en": "Set child lock" },
      "args": [{ "name": "enabled", "type": "boolean", "title": { "en": "Enabled" } }]
    },
    {
      "id": "switch_1gang_set_scene_mode",
      "title": { "en": "Set scene mode" },
      "args": [{ "name": "mode", "type": "number", "title": { "en": "Scene mode" } }]
    },
    {
      "id": "switch_1gang_set_power_on_behavior",
      "title": { "en": "Set power-on behavior" },
      "args": [{ "name": "behavior", "type": "dropdown", "values": [{ "id": "off", "label": "Off" }, { "id": "on", "label": "On" }, { "id": "previous", "label": "Previous state" }], "title": { "en": "Behavior" } }]
    }
  ]
}