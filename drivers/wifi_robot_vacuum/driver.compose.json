  "pair": [
    {
      "id": "configure",
      "navigation": {
        "next": "list_devices"
      }
    },
    {
      "id": "list_devices",
      "template": "list_devices",
      "navigation": {
        "prev": "configure"
      }
    },
    {
      "id": "add_devices",
      "template": "add_devices"
    }
  ],
  "repair": [
    {
      "id": "configure"
    }
  ],
  "settings": [
    {
      "type": "group",
      "label": {
        "en": "Tuya Local"
      },
      "children": [
        {
          "id": "device_id",
          "type": "text",
          "label": {
            "en": "Device ID"
          },
          "value": ""
        },
        {
          "id": "local_key",
          "type": "text",
          "label": {
            "en": "Local Key"
          },
          "value": ""
        },
        {
          "id": "ip",
          "type": "text",
          "label": {
            "en": "IP"
          },
          "value": ""
        },
        {
          "id": "protocol_version",
          "type": "dropdown",
          "label": {
            "en": "Protocol"
          },
          "value": "3.3",
          "values": [
            {
              "id": "3.1",
              "label": {
                "en": "3.1"
              }
            },
            {
              "id": "3.3",
              "label": {
                "en": "3.3"
              }
            },
            {
              "id": "3.4",
              "label": {
                "en": "3.4"
              }
            },
            {
              "id": "3.5",
              "label": {
                "en": "3.5"
              }
            }
          ]
        }
      ]
    },
    {
      "type": "group",
      "label": {
        "en": "Vacuum Settings (Idea #25)"
      },
      "hint": {
        "en": "Configure vacuum cleaning preferences"
      },
      "children": [
        {
          "id": "default_mode",
          "type": "dropdown",
          "label": {
            "en": "Default Vacuum Mode"
          },
          "value": "standard",
          "values": [
            { "id": "silent", "label": { "en": "Silent" } },
            { "id": "standard", "label": { "en": "Standard" } },
            { "id": "strong", "label": { "en": "Strong" } },
            { "id": "super", "label": { "en": "Super" } }
          ],
          "hint": {
            "en": "Default suction power when starting a clean cycle"
          }
        },
        {
          "id": "default_clean_mode",
          "type": "dropdown",
          "label": {
            "en": "Default Cleaning Mode"
          },
          "value": "sweep_and_mop",
          "values": [
            { "id": "sweep", "label": { "en": "Sweep Only" } },
            { "id": "mop", "label": { "en": "Mop Only" } },
            { "id": "sweep_and_mop", "label": { "en": "Sweep + Mop" } }
          ],
          "hint": {
            "en": "Default cleaning mode (requires robot with mopping capability)"
          }
        },
        {
          "id": "auto_dock_after_clean",
          "type": "checkbox",
          "label": {
            "en": "Auto Return to Dock"
          },
          "value": true,
          "hint": {
            "en": "Automatically return to charging dock after cleaning completes"
          }
        }
      ]
    }
  ],
  "images": {
    "small": "/drivers/wifi_robot_vacuum/assets/images/small.png",
    "large": "/drivers/wifi_robot_vacuum/assets/images/large.png",
    "xlarge": "/drivers/wifi_robot_vacuum/assets/images/xlarge.png"
  },
  "platforms": [
    "local"
  ],
  "connectivity": [
    "lan"
  ],
  "energy": {
    "batteries": [
      "INTERNAL"
    ]
  },
  "maintenanceActions": [
    {
      "id": "ota_check",
      "title": {
        "en": "Check Zigbee OTA Update",
        "fr": "Vérifier MàJ OTA",
        "nl": "Controleer op OTA-updates"
      }
    }
  ],
  "id": "wifi_robot_vacuum",
  "version": "1.0.0"
}
