  "conditions": [
    {
      "id": "device_air_purifier_water_water_tank_monitor_level_above",
      "title": {
        "en": "Fill level !{{is|is not}} above",
        "nl": "Vulniveau !{{is|is niet}} boven",
        "fr": "Niveau !{{est|n'est pas}} au-dessus de",
        "de": "Fullstand !{{ist|ist nicht}} uber"
      },
      "titleFormatted": {
        "en": "Fill level !{{is|is not}} above [[level]]%",
        "nl": "Vulniveau !{{is|is niet}} boven [[level]]%",
        "fr": "Niveau !{{est|n'est pas}} au-dessus de [[level]]%",
        "de": "Fullstand !{{ist|ist nicht}} uber [[level]]%"
      },
