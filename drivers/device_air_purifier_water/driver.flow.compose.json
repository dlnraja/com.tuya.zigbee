        "de": "Flussigkeitsstand niedrig"
      }
    },
    {
      "id": "device_air_purifier_water_water_tank_monitor_high",
      "title": {
        "en": "Liquid level is high",
        "nl": "Vloeistofniveau is hoog",
        "fr": "Niveau liquide haut",
        "de": "Flussigkeitsstand hoch"
      },
      "args": [],
      "titleFormatted": {
        "en": "Liquid level is high",
        "nl": "Vloeistofniveau is hoog",
        "fr": "Niveau liquide haut",
        "de": "Flussigkeitsstand hoch"
      }
    }
