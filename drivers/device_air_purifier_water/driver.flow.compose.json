      "args": [
        {
          "name": "state",
          "type": "dropdown",
          "values": [
            {
              "id": "low",
              "label": {
                "en": "Low"
              }
            },
            {
              "id": "normal",
              "label": {
                "en": "Normal"
              }
            },
            {
              "id": "high",
              "label": {
                "en": "High"
              }
            }
          ]
        }
      ]
