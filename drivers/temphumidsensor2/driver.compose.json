        "bindings": [
          1,
          1026,
          1029
        ]
      }
    },
    "learnmode": {
      "image": "{{driverAssetsPath}}/learn.svg",
      "instruction": {
        "en": "Insert a pin into the single hole on the side of the device and press it gently for aprox 10 seconds until the LED blinks rapidly."
      }
