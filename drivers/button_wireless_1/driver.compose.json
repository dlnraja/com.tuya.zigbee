      "value": 10,
      "min": 0,
      "max": 30,
      "step": 5,
      "hint": {
        "en": "Trigger critical battery warning when below this percentage",
        "fr": "Déclencher l'alerte batterie critique en dessous de ce pourcentage"
      }
    },
