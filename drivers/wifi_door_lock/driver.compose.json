{
  "name": {
    "en": "WiFi Door Lock (Tuya Local)"
  },
  "class": "lock",
  "capabilities": [
    "locked",
    "measure_battery",
    "alarm_generic",
    "alarm_contact"
  ],
  "pair": [
    {
      "id": "configure",
      "navigation": {
        "next": "list_devices"
      }
    },
    {
      "id": "list_devices",
      "template": "list_devices",
      "navigation": {
        "prev": "configure"
      }
    },
    {
      "id": "add_devices",
      "template": "add_devices"
    }
  ],
  "repair": [
    {
      "id": "configure"
    }
  ],
  "settings": [
    {
      "type": "group",
      "label": {
        "en": "Tuya Local"
      },
      "children": [
        {
          "id": "device_id",
          "type": "text",
          "label": {
            "en": "Device ID"
          },
          "value": ""
        },
        {
          "id": "local_key",
          "type": "text",
          "label": {
            "en": "Local Key"
          },
          "value": ""
        },
        {
          "id": "ip",
          "type": "text",
          "label": {
            "en": "IP"
          },
          "value": ""
        },
        {
          "id": "protocol_version",
          "type": "dropdown",
          "label": {
            "en": "Protocol"
          },
          "value": "3.3",
          "values": [
            {
              "id": "3.1",
              "label": {
                "en": "3.1"
              }
            },
            {
              "id": "3.3",
              "label": {
                "en": "3.3"
              }
            },
            {
              "id": "3.4",
              "label": {
                "en": "3.4"
              }
            },
            {
              "id": "3.5",
              "label": {
                "en": "3.5"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "sync_email",
      "type": "text",
      "label": {
        "en": "Cloud Sync Email",
        "fr": "Email de synchronisation"
      },
      "hint": {
        "en": "Optional: Email for automatic local key retrieval",
        "fr": "Optionnel : Email pour récupération auto des clés"
      }
    },
    {
      "id": "sync_password",
      "type": "password",
      "label": {
        "en": "Cloud Sync Password",
        "fr": "Mot de passe de synchronisation"
      },
      "hint": {
        "en": "Optional: Password for the Tuya/Smart Life app",
        "fr": "Optionnel : Mot de passe de l'app Tuya/Smart Life"
      }
    }
  ],
  "images": {
    "small": "drivers/wifi_door_lock/assets/images/small.png",
    "large": "drivers/wifi_door_lock/assets/images/large.png",
    "xlarge": "drivers/wifi_door_lock/assets/images/xlarge.png"
  },
  "platforms": [
    "local"
  ],
  "connectivity": [
    "lan"
  ],
  "energy": {
    "batteries": [
      "CR2450"
    ],
    "mains": true
  },
  "maintenanceActions": [
    {
      "id": "ota_check",
      "title": {
        "en": "Check Zigbee OTA Update",
        "fr": "Vérifier MàJ OTA",
        "nl": "Controleer op OTA-updates"
      }
    }
  ],
  "discoveryStrategies": [
    {
      "strategy": "mdns-sd",
      "options": {
        "name": "_tuya._tcp.local"
      }
    },
    {
      "strategy": "ssdp",
      "options": {
        "search": "urn:schemas-upnp-org:device:Basic:1"
      }
    }
  ],
  "flow": {
    "triggers": [
      {
        "id": "radio_presence_detected",
        "title": {
          "en": "Radio sensing presence detected",
          "fr": "Présence détectée par radio (LQI)"
        }
      }
    ],
    "conditions": [
      {
        "id": "is_radio_presence_detected",
        "title": {
          "en": "Radio presence is detected",
          "fr": "Présence radio détectée"
        }
      }
    ],
    "actions": [
      {
        "id": "calibrate_virtual_energy",
        "title": {
          "en": "Calibrate virtual energy",
          "fr": "Calibrer l'énergie virtuelle"
        },
        "args": [
          {
            "name": "watts",
            "type": "number",
            "placeholder": {
              "en": "Nominal Watts",
              "fr": "Watts nominaux"
            }
          }
        ]
      },
      {
        "id": "set_sensing_threshold",
        "title": {
          "en": "Set radio sensing sensitivity",
          "fr": "Régler la détection radio"
        },
        "args": [
          {
            "name": "threshold",
            "type": "number",
            "placeholder": "2-50"
          }
        ]
      }
    ]
  }
}