          "units": "°C",
          "value": 0,
          "min": -10,
          "max": 10,
          "step": 0.1
        },
        {
          "id": "humidity_offset",
          "type": "number",
          "label": {
            "en": "Humidity offset",
            "nl": "Luchtvochtigheid correctie"
          },
