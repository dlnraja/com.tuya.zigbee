      "tokens": [
        {
          "name": "distance",
          "type": "number",
          "title": {
            "en": "Distance (cm)",
            "nl": "Afstand (cm)",
            "fr": "Distance (cm)",
            "de": "Abstand (cm)"
          },
          "example": 200
        }
      ],
      "args": []
    },
    {
      "id": "sensor_illuminance_presence_lux_changed",
      "title": {
