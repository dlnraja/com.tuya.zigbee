{
  "triggers": [
    {
      "id": "sensor_illuminance_presence_presence_detected",
      "highlight": true,
      "title": {
        "en": "Presence detected",
        "nl": "Aanwezigheid gedetecteerd",
        "fr": "Présence détectée",
        "de": "Anwesenheit erkannt"
      },
      "hint": {
        "en": "Triggers when the mmWave radar detects human presence (even stationary)",
        "nl": "Triggert wanneer de mmWave radar menselijke aanwezigheid detecteert (zelfs stilstaand)",
        "fr": "Se déclenche quand le radar mmWave détecte une présence humaine (même immobile)",
        "de": "Wird ausgelöst, wenn der mmWave-Radar menschliche Anwesenheit erkennt (auch stationär)"
      },
      "args": []
    },
    {
      "id": "sensor_illuminance_presence_presence_cleared",
      "title": {
        "en": "Presence cleared",
        "nl": "Aanwezigheid opgeheven",
        "fr": "Présence terminée",
        "de": "Anwesenheit beendet"
      },
      "hint": {
        "en": "Triggers when no human presence is detected for the configured timeout",
        "nl": "Triggert wanneer geen menselijke aanwezigheid wordt gedetecteerd gedurende de geconfigureerde timeout",
        "fr": "Se déclenche quand aucune présence humaine n'est détectée pendant le délai configuré",
        "de": "Wird ausgelöst, wenn für die konfigurierte Zeitüberschreitung keine menschliche Anwesenheit erkannt wird"
      },
      "args": []
    },
    {
      "id": "sensor_illuminance_presence_motion_detected",
      "title": {
        "en": "Motion detected",
        "nl": "Beweging gedetecteerd",
        "fr": "Mouvement détecté",
        "de": "Bewegung erkannt"
      },
      "hint": {
        "en": "Triggers when active motion is detected (walking, moving)",
        "nl": "Triggert wanneer actieve beweging wordt gedetecteerd (lopen, bewegen)",
        "fr": "Se déclenche quand un mouvement actif est détecté (marche, mouvement)",
        "de": "Wird ausgelöst, wenn aktive Bewegung erkannt wordt (Gehen, Bewegen)"
      },
      "args": []
    },
    {
      "id": "sensor_illuminance_presence_illuminance_changed",
      "title": {
        "en": "Illuminance changed",
