{
  "name": {
    "en": "Device Air Purifier Thermostat Hybrid",
    "nl": "Hybride Luchtzuiveraar Thermostaat",
    "fr": "Thermostat Hybride Purificateur d'Air",
    "de": "Hybrid-Luftreiniger-Thermostat",
    "es": "Termostato Híbrido Purificador de Aire"
  },
  "class": "thermostat",
  "capabilities": [
    "target_temperature",
    "measure_temperature",
    "thermostat_mode",
    "measure_battery",
    "onoff",
    "measure_humidity",
    "dim",
    "measure_pm25"
  ],
  "platforms": [
    "local"
  ],
  "connectivity": [
    "zigbee"
  ],
  "zigbee": {
    "manufacturerName": [],
    "productId": [
      "TS0601",
      "ts0601"
    ],
    "endpoints": {
      "1": {
        "clusters": [
          0,
          6
        ]
      }
    }
  },
  "images": {
    "large": "drivers/thermostat_tuya_dp/assets/images/large.png",
    "small": "drivers/thermostat_tuya_dp/assets/images/small.png",
    "xlarge": "drivers/thermostat_tuya_dp/assets/images/xlarge.png"
  },
  "energy": {
    "batteries": [
      "CR2450"
    ],
    "mains": true
  },
  "maintenanceActions": [
    {
      "id": "ota_check",
      "title": {
        "en": "Check Zigbee OTA Update",
        "fr": "Vérifier MàJ OTA",
        "nl": "Controleer op OTA-updates"
      }
    }
  ],
  "flow": {
    "triggers": [
      {
        "id": "radio_presence_detected",
        "title": {
          "en": "Radio sensing presence detected",
          "fr": "Présence détectée par radio (LQI)"
        }
      }
    ],
    "conditions": [
      {
        "id": "is_radio_presence_detected",
        "title": {
          "en": "Radio presence is detected",
          "fr": "Présence radio détectée"
        }
      }
    ],
    "actions": [
      {
        "id": "calibrate_virtual_energy",
        "title": {
          "en": "Calibrate virtual energy",
          "fr": "Calibrer l'énergie virtuelle"
        },
        "args": [
          {
            "name": "watts",
            "type": "number",
            "placeholder": {
              "en": "Nominal Watts",
              "fr": "Watts nominaux"
            }
          }
        ]
      },
      {
        "id": "set_sensing_threshold",
        "title": {
          "en": "Set radio sensing sensitivity",
          "fr": "Régler la détection radio"
        },
        "args": [
          {
            "name": "threshold",
            "type": "number",
            "placeholder": "2-50"
          }
        ]
      }
    ]
  }
}