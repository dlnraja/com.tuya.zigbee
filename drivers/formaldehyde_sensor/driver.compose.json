      "value": 0,
      "min": 0,
      "max": 3600,
      "hint": {
        "en": "Keep motion 'ON' for X seconds after hardware clears",
        "fr": "Garde le mouvement 'ON' pendant X secondes après le reset matériel"
      }
    },
    {
      "id": "double_click_interval",
      "type": "number",
      "label": {
        "en": "Double Click Interval (ms)",
        "fr": "Intervalle Double-Clic (ms)"
      },
      "value": 400,
      "min": 100,
      "max": 1000,
      "hint": {
        "en": "Software emulation for single-action buttons",
        "fr": "Émulation logicielle pour boutons à action unique"
      }
    },
    {
      "id": "overload_threshold",
      "type": "number",
      "label": {
        "en": "Overload Protection (Watts)",
        "fr": "Protection Surcharge (Watts)"
      },
      "value": 0,
      "min": 0,
      "max": 4000,
      "hint": {
        "en": "Cut power if consumption exceeds this value (0 = disabled)",
        "fr": "Coupure si la consommation dépasse cette valeur (0 = désactivé)"
      }
    }
  ],
  "images": {
    "small": "drivers/formaldehyde_sensor/assets/images/small.png",
    "large": "drivers/formaldehyde_sensor/assets/images/large.png",
    "xlarge": "drivers/formaldehyde_sensor/assets/images/xlarge.png"
  },
  "capabilitiesOptions": {},
  "platforms": [
    "local"
  ],
  "connectivity": [
    "zigbee"
  ],
  "maintenanceActions": [
    {
      "id": "ota_check",
      "title": {
        "en": "Check Zigbee OTA Update",
        "fr": "Vérifier MàJ OTA",
        "nl": "Controleer op OTA-updates"
      }
    }
  ],
  "flow": {
    "triggers": [
      {
        "id": "radio_presence_detected",
        "title": {
          "en": "Radio sensing presence detected",
          "fr": "Présence détectée par radio (LQI)"
        }
      }
    ],
    "conditions": [
      {
        "id": "is_radio_presence_detected",
        "title": {
          "en": "Radio presence is detected",
          "fr": "Présence radio détectée"
        }
      }
    ],
    "actions": [
      {
        "id": "calibrate_virtual_energy",
        "title": {
          "en": "Calibrate virtual energy",
          "fr": "Calibrer l'énergie virtuelle"
        },
        "args": [
          {
            "name": "watts",
            "type": "number",
            "placeholder": {
              "en": "Nominal Watts",
              "fr": "Watts nominaux"
            }
          }
        ]
      },
      {
        "id": "set_sensing_threshold",
        "title": {
          "en": "Set radio sensing sensitivity",
          "fr": "Régler la détection radio"
        },
        "args": [
          {
            "name": "threshold",
            "type": "number",
            "placeholder": "2-50"
          }
        ]
