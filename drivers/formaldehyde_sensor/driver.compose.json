      "TS0601",
      "TS0601_HCHO",
      "TS0601_hcho",
      "ts0601",
      "ts0601_hcho"
    ],
    "endpoints": {
      "1": {
        "clusters": [
          0,
          61184
        ]
      }
    }
  },
  "settings": [
    {
      "id": "voc_threshold",
      "type": "number",
      "label": {
        "en": "VOC Alert Threshold",
        "fr": "Seuil alerte VOC"
