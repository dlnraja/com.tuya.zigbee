      "value": 15,
      "min": 5,
      "max": 50,
      "hint": {
        "en": "LQI variance threshold (higher = less sensitive)",
        "fr": "Seuil de variance LQI (plus haut = moins sensible)"
      }
    },
    {
      "id": "enable_software_child_lock",
      "type": "checkbox",
      "label": {
        "en": "Software Child Lock",
        "fr": "Sécurité Enfant Logicielle"
