{
  "name": {
    "en": "Zigbee Formaldehyde/VOC Sensor",
    "fr": "Capteur formaldéhyde/VOC Zigbee",
    "nl": "Formaldehyde Sensor",
    "de": "Formaldehyd Sensor"
  },
  "class": "sensor",
  "capabilities": [
    "measure_co2",
    "measure_temperature",
    "measure_humidity",
    "measure_pm25",
    "measure_battery"
  ],
  "energy": {
    "approximation": {
      "usageOn": 1,
      "usageOff": 0.5
    },
    "batteries": [
      "CR2450"
    ],
    "mains": true
  },
  "subDevices": [],
  "zigbee": {
    "manufacturerName": [
      "_TZE200_MCE9KJPM",
      "_tze200_mce9kjpm"
    ],
    "productId": [
      "TS0601",
      "TS0601_HCHO",
      "TS0601_hcho",
      "ts0601",
      "ts0601_hcho"
    ],
    "endpoints": {
      "1": {
        "clusters": [
          0,
          61184
        ]
      }
    }
  },
  "settings": [
    {
      "id": "voc_threshold",
      "type": "number",
      "label": {
        "en": "VOC Alert Threshold",
        "fr": "Seuil alerte VOC"
      },
      "value": 500,
      "min": 100,
      "max": 2000,
      "units": "ppb"
    },
    {
      "id": "sensor_precision",
      "type": "dropdown",
      "label": {
        "en": "Decimal Precision",
        "fr": "Précision"
      },
      "value": "1",
      "hint": {
        "en": "Decimals for temperature/humidity values"
      },
      "values": [
        {
          "id": "1",
          "label": {
            "en": "1 decimal (20.5°C)"
          }
        },
        {
          "id": "2",
          "label": {
            "en": "2 decimals (20.53°C)"
          }
        }
      ]
    }
  ],
  "images": {
    "small": "drivers/formaldehyde_sensor/assets/images/small.png",
    "large": "drivers/formaldehyde_sensor/assets/images/large.png",
    "xlarge": "drivers/formaldehyde_sensor/assets/images/xlarge.png"
  },
  "capabilitiesOptions": {},
  "platforms": [
    "local"
  ],
  "connectivity": [
    "zigbee"
  ],
  "maintenanceActions": [
    {
      "id": "ota_check",
      "title": {
        "en": "Check Zigbee OTA Update",
        "fr": "Vérifier MàJ OTA",
        "nl": "Controleer op OTA-updates"
      }
    }
  ],
  "flow": {
    "triggers": [
      {
        "id": "radio_presence_detected",
        "title": {
          "en": "Radio sensing presence detected",
          "fr": "Présence détectée par radio (LQI)"
        }
      }
    ],
    "conditions": [
      {
        "id": "is_radio_presence_detected",
        "title": {
          "en": "Radio presence is detected",
          "fr": "Présence radio détectée"
        }
      }
    ],
    "actions": [
      {
        "id": "calibrate_virtual_energy",
        "title": {
          "en": "Calibrate virtual energy",
          "fr": "Calibrer l'énergie virtuelle"
        },
        "args": [
          {
            "name": "watts",
            "type": "number",
            "placeholder": {
              "en": "Nominal Watts",
              "fr": "Watts nominaux"
            }
          }
        ]
      },
      {
        "id": "set_sensing_threshold",
        "title": {
          "en": "Set radio sensing sensitivity",
          "fr": "Régler la détection radio"
        },
        "args": [
          {
            "name": "threshold",
            "type": "number",
            "placeholder": "2-50"
          }
        ]
      }
    ]
  }
}