      "hint": {
        "en": "Balance between responsiveness and battery life",
        "fr": "Équilibre entre réactivité et durée de vie de la batterie"
      }
    },
    {
      "id": "show_voltage",
      "type": "checkbox",
      "label": {
        "en": "Show Battery Voltage",
        "fr": "Afficher Tension Batterie"
