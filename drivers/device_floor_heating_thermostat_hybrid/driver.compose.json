{
  "name": {
    "en": "Device Floor Heating Thermostat Hybrid",
    "nl": "Hybride thermostaat voor vloerverwarming",
    "fr": "Thermostat hybride pour chauffage au sol",
    "de": "Hybrider Thermostat für Fußbodenheizung",
    "es": "Termostato híbrido para calefacción por suelo radiante"
  },
  "class": "thermostat",
  "capabilities": [
    "target_temperature",
    "measure_temperature",
    "measure_temperature.floor",
    "thermostat_mode",
    "onoff",
    "measure_battery"
