  "capabilitiesOptions": {
    "target_temperature": {
      "min": 5,
      "max": 45,
      "step": 0.5
    },
    "measure_temperature.floor": {
      "title": {
        "en": "Floor Temperature",
        "fr": "Température Sol"
      }
    },
    "thermostat_mode": {
      "values": [
        {
          "id": "auto",
          "title": {
            "en": "Schedule"
          }
        },
        {
          "id": "heat",
          "title": {
            "en": "Manual"
          }
        },
        {
          "id": "off",
          "title": {
            "en": "Off"
          }
        }
      ]
    }
  },
  "zigbee": {
    "manufacturerName": [],
    "productId": [
      "TS0601",
      "ts0601"
    ],
    "endpoints": {
      "1": {
        "clusters": [
          0,
          61184
        ]
      }
    }
  },
  "images": {
    "small": "drivers/floor_heating_thermostat/assets/images/small.png",
    "large": "drivers/floor_heating_thermostat/assets/images/large.png",
    "xlarge": "drivers/floor_heating_thermostat/assets/images/xlarge.png"
  },
  "platforms": [
    "local"
  ],
  "connectivity": [
    "zigbee"
  ],
  "energy": {
    "batteries": [
      "CR2450"
    ],
    "approximation": {
      "usageConstant": 2
    },
    "mains": true
  },
  "maintenanceActions": [
    {
      "id": "ota_check",
      "title": {
        "en": "Check Zigbee OTA Update",
        "fr": "Vérifier MàJ OTA",
        "nl": "Controleer op OTA-updates"
      }
    }
  ],
  "flow": {
    "triggers": [
      {
        "id": "radio_presence_detected",
        "title": {
          "en": "Radio sensing presence detected",
          "fr": "Présence détectée par radio (LQI)"
        }
      }
    ],
    "conditions": [
      {
        "id": "is_radio_presence_detected",
        "title": {
          "en": "Radio presence is detected",
          "fr": "Présence radio détectée"
        }
      }
    ],
    "actions": [
      {
        "id": "calibrate_virtual_energy",
        "title": {
          "en": "Calibrate virtual energy",
          "fr": "Calibrer l'énergie virtuelle"
        },
        "args": [
          {
            "name": "watts",
            "type": "number",
            "placeholder": {
              "en": "Nominal Watts",
              "fr": "Watts nominaux"
            }
          }
        ]
      },
      {
        "id": "set_sensing_threshold",
        "title": {
          "en": "Set radio sensing sensitivity",
          "fr": "Régler la détection radio"
        },
        "args": [
          {
            "name": "threshold",
            "type": "number",
            "placeholder": "2-50"
          }
        ]
      }
    ]
  }
