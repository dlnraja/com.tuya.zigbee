{
  "name": {
    "en": "Virtual IR Remote",
    "fr": "Télécommande IR Virtuelle"
  },
  "class": "other",
  "capabilities": [
    "onoff",
    "onoff.ir_learn",
    "button.ir_test"
  ],
  "capabilitiesOptions": {
    "onoff": {
      "title": {
        "en": "Power",
        "fr": "Alimentation"
      }
    },
    "onoff.ir_learn": {
      "title": {
        "en": "Learning Mode",
        "fr": "Mode Apprentissage"
      },
      "icon": "/assets/icons/learn.svg"
    }
  },
  "settings": [
    {
      "id": "blaster_id",
      "type": "text",
      "label": {
        "en": "Associated IR Blaster ID",
        "fr": "ID du Blaster IR associé"
      },
      "hint": {
        "en": "Internal ID of the physical IR Blaster device",
        "fr": "ID interne du module IR Blaster physique"
      },
      "value": ""
    },
    {
      "id": "ir_brand",
      "type": "text",
      "label": {
        "en": "Brand",
        "fr": "Marque"
      },
      "value": "Samsung"
    },
    {
      "id": "ir_category",
      "type": "dropdown",
      "label": {
        "en": "Device Category",
        "fr": "Catégorie d'appareil"
      },
      "values": [
        { "id": "TV", "label": { "en": "TV", "fr": "TV" } },
        { "id": "AC", "label": { "en": "AC", "fr": "Climatiseur" } },
        { "id": "Fan", "label": { "en": "Fan", "fr": "Ventilateur" } },
        { "id": "Audio", "label": { "en": "Audio", "fr": "Audio" } },
        { "id": "Light", "label": { "en": "Light", "fr": "Lumière" } }
      ],
      "value": "TV"
    }
  ],
  "pair": [
    {
      "id": "list_blasters",
      "template": "list_devices",
      "options": {
        "driverId": "ir_blaster"
      }
    },
    {
      "id": "select_brand",
      "template": "repair",
      "options": {
        "view": "ir_setup"
      }
    }
  ],
  "images": {
    "large": "/drivers/ir_remote/assets/images/large.png",
    "small": "/drivers/ir_remote/assets/images/small.png"
  }
}
