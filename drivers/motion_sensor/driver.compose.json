          "label": {
            "en": "Battery Powered",
            "fr": "Sur Batterie"
          }
        }
      ],
      "hint": {
        "en": "Select power source manually or use auto-detection",
        "fr": "Sélectionnez la source d'alimentation manuellement ou utilisez la détection automatique"
      }
    },
