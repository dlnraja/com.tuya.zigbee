{
  "id": "outdoorplug",
  "name": {
    "en": "Outdoor Plug without metering"
  },
  "class": "socket",
  "platforms": [
    "local"
  ],
  "connectivity": [
    "zigbee"
  ],
  "capabilities": [
    "onoff",
    "button.1"
  ],
  "capabilitiesOptions": {
    "measure_power": {
      "approximated": true
    },
    "button.1": {
      "title": {
        "en": "Button 1",
        "fr": "Bouton 1"
      },
      "maintenanceAction": true,
      "getable": false,
      "setable": false
    }
  },
  "images": {
    "large": "/{{driverAssetsPath}}/images/large.png",
    "small": "/{{driverAssetsPath}}/images/small.png"
