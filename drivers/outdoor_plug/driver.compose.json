    "productId": [
      "TS0101",
      "TS0049"
    ],
    "endpoints": {
      "1": {
        "clusters": [
          0,
          4,
          5,
          6
        ],
        "bindings": [
          6
        ]
      }
    },
    "learnmode": {
      "instruction": {
        "en": "Press and hold down on/off switch for aprox 5 seconds until the LED blinks rapidly."
      }
    },
    "manufacturerName": [
      "_TZE200_dummy",
      "_TZ3000_pnzfdr9y",
      "_TZ3000_br3laukf"
    ]
  },
  "version": "1.0.0",
  "metadata": {
    "driver": {
      "catchall": true,
      "reason": "Fallback for unmatched devices with PIDs: TS0101"
    }
  }
