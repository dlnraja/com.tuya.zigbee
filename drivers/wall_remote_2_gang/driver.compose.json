{
  "id": "wall_remote_2_gang",
  "name": {
    "en": "2 Gang Wall Remote"
  },
  "class": "remote",
  "platforms": [
    "local"
  ],
  "connectivity": [
    "zigbee"
  ],
  "capabilities": [
    "button.1",
    "button.2",
    "measure_battery"
  ],
  "capabilitiesOptions": {
    "button.1": {
      "title": {
        "en": "Button 1",
        "fr": "Bouton 1",
        "nl": "Knop 1",
        "de": "Taste 1"
      }
    },
    "button.2": {
      "title": {
        "en": "Button 2",
        "fr": "Bouton 2",
        "nl": "Knop 2",
        "de": "Taste 2"
      }
    },
    "measure_battery": {
      "title": {
        "en": "Battery",
        "fr": "Batterie",
        "nl": "Batterij",
        "de": "Batterie"
      }
    }
  },
  "images": {
    "large": "drivers/wall_remote_2_gang/assets/images/large.png",
    "small": "drivers/wall_remote_2_gang/assets/images/small.png",
    "xlarge": "drivers/wall_remote_2_gang/assets/images/xlarge.png"
  },
  "energy": {
    "batteries": [
      "CR2450"
    ],
    "mains": true
  },
  "zigbee": {
    "manufacturerName": [
      "_TZ3000_TZVBIMPQ",
      "_tz3000_tzvbimpq"
    ],
    "productId": [
      "TS0042",
      "ts0042"
    ],
    "endpoints": {
      "1": {
        "clusters": [
          0,
          6
        ]
      },
      "2": {
        "clusters": [
          6
        ]
      }
    },
    "learnmode": {
      "image": "{{driverAssetsPath}}/icon.svg",
      "instruction": {
        "en": "Press the left button for aprox 10 seconds (the LED should start blinking). A tile for each button will be created. "
      }
    }
  },
  "settings": [
    {
      "id": "button_mode",
      "type": "dropdown",
      "label": {
        "en": "Operating Mode",
        "fr": "Mode de fonctionnement"
      },
      "hint": {
        "en": "Scene Mode allows single/double/long press. Dimmer Mode only supports single press. Auto tries to detect and switch automatically.",
        "fr": "Le mode Scène permet les appuis simples/doubles/longs. Le mode Variateur ne supporte que l'appui simple. Auto tente de détecter et basculer automatiquement."
      },
      "value": "auto",
      "values": [
        {
          "id": "auto",
          "label": {
            "en": "Auto-Detect",
            "fr": "Détection Auto"
          }
        },
        {
          "id": "scene",
          "label": {
            "en": "Scene Mode (Multi-press)",
            "fr": "Mode Scène (Multi-clics)"
          }
        },
        {
          "id": "dimmer",
          "label": {
            "en": "Dimmer Mode",
            "fr": "Mode Variateur"
          }
        }
      ]
    }
  ],
  "maintenanceActions": [
    {
      "id": "ota_check",
      "title": {
        "en": "Check Zigbee OTA Update",
        "fr": "Vérifier MàJ OTA",
        "nl": "Controleer op OTA-updates"
      }
    }
  ],
  "flow": {
    "triggers": [
      {
        "id": "radio_presence_detected",
        "title": {
          "en": "Radio sensing presence detected",
          "fr": "Présence détectée par radio (LQI)"
        }
      }
    ],
    "conditions": [
      {
        "id": "is_radio_presence_detected",
        "title": {
          "en": "Radio presence is detected",
          "fr": "Présence radio détectée"
        }
      }
    ],
    "actions": [
      {
        "id": "calibrate_virtual_energy",
        "title": {
          "en": "Calibrate virtual energy",
          "fr": "Calibrer l'énergie virtuelle"
        },
        "args": [
          {
            "name": "watts",
            "type": "number",
            "placeholder": {
              "en": "Nominal Watts",
              "fr": "Watts nominaux"
            }
          }
        ]
      },
      {
        "id": "set_sensing_threshold",
        "title": {
          "en": "Set radio sensing sensitivity",
          "fr": "Régler la détection radio"
        },
        "args": [
          {
            "name": "threshold",
            "type": "number",
            "placeholder": "2-50"
          }
        ]
      }
    ]
  }
}