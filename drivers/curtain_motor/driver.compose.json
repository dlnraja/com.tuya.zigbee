          "label": {
            "en": "Balanced",
            "fr": "Équilibré"
          }
        },
        {
          "id": "power_saving",
          "label": {
            "en": "Power Saving (Longer battery)",
            "fr": "Économie d'énergie (Batterie plus longue)"
          }
        }
      ],
      "hint": {
        "en": "Balance between responsiveness and battery life",
        "fr": "Équilibre entre réactivité et durée de vie de la batterie"
      }
