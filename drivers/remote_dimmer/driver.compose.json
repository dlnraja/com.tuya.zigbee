{
  "name": {
    "en": "Remote Control Dimmer (Lidl/Tuya)",
    "fr": "Télécommande Variateur (Lidl/Tuya)",
    "nl": "Afstandsbediening Dimmer (Lidl/Tuya)",
    "de": "Fernbedienung Dimmer (Lidl/Tuya)"
  },
  "class": "remote",
  "connectivity": [
    "zigbee"
  ],
  "capabilities": [
    "measure_battery"
  ],
  "energy": {
    "batteries": [
      "CR2450"
    ],
    "mains": true
  },
  "zigbee": {
    "manufacturerName": [
      "_TYZB01_BNGWDJSR",
      "_tyzb01_bngwdjsr"
    ],
    "productId": [
      "TS1001",
      "ts1001"
    ],
    "endpoints": {
      "1": {
        "clusters": [
          0,
          1,
          3,
          4,
          4096
        ]
      }
    },
    "learnmode": {
      "image": "/drivers/remote_dimmer/assets/learnmode.svg",
      "instruction": {
        "en": "Press and hold the pairing button for 5 seconds until the LED flashes rapidly.",
        "fr": "Appuyez et maintenez le bouton d'appairage pendant 5 secondes jusqu'au clignotement rapide de la LED.",
        "nl": "Houd de koppelknop 5 seconden ingedrukt tot de LED snel knippert.",
        "de": "Halten Sie die Kopplungstaste 5 Sekunden lang gedrückt, bis die LED schnell blinkt."
      }
    }
  },
  "images": {
    "large": "drivers/remote_dimmer/assets/images/large.png",
    "small": "drivers/remote_dimmer/assets/images/small.png",
    "xlarge": "drivers/remote_dimmer/assets/images/xlarge.png"
  },
  "maintenanceActions": [
    {
      "id": "ota_check",
      "title": {
        "en": "Check Zigbee OTA Update",
        "fr": "Vérifier MàJ OTA",
        "nl": "Controleer op OTA-updates"
      }
    }
  ],
  "flow": {
    "triggers": [
      {
        "id": "radio_presence_detected",
        "title": {
          "en": "Radio sensing presence detected",
          "fr": "Présence détectée par radio (LQI)"
        }
      }
    ],
    "conditions": [
      {
        "id": "is_radio_presence_detected",
        "title": {
          "en": "Radio presence is detected",
          "fr": "Présence radio détectée"
        }
      }
    ],
    "actions": [
      {
        "id": "calibrate_virtual_energy",
        "title": {
          "en": "Calibrate virtual energy",
          "fr": "Calibrer l'énergie virtuelle"
        },
        "args": [
          {
            "name": "watts",
            "type": "number",
            "placeholder": {
              "en": "Nominal Watts",
              "fr": "Watts nominaux"
            }
          }
        ]
      },
      {
        "id": "set_sensing_threshold",
        "title": {
          "en": "Set radio sensing sensitivity",
          "fr": "Régler la détection radio"
        },
        "args": [
          {
            "name": "threshold",
            "type": "number",
            "placeholder": "2-50"
          }
        ]
      }
    ]
  }
}