          "type": "label",
          "label": {
            "en": "ZCL Clusters",
            "fr": "Clusters ZCL"
          },
          "value": "Scanning..."
        },
        {
          "id": "discovered_capabilities",
          "type": "label",
          "label": {
            "en": "Capabilities Added",
            "fr": "Capacités Ajoutées"
          },
          "value": "None yet"
        }
      ]
    },
    {
      "type": "group",
      "label": {
        "en": "⚙️ Advanced",
        "fr": "⚙️ Avancé"
      },
      "children": [
        {
          "id": "force_rescan",
          "type": "checkbox",
          "label": {
            "en": "Force Cluster Rescan",
            "fr": "Forcer Rescan Clusters"
          },
          "value": false,
          "hint": {
            "en": "Enable to rescan clusters on next init",
            "fr": "Activer pour rescanner les clusters au prochain démarrage"
          }
        }
      ]
    }
  ],
  "platforms": [
    "local"
  ],
  "connectivity": [
    "zigbee"
  ],
  "maintenanceActions": [
    {
      "id": "ota_check",
      "title": {
        "en": "Check Zigbee OTA Update",
        "fr": "Vérifier MàJ OTA",
        "nl": "Controleer op OTA-updates"
      }
    }
  ],
  "flow": {
    "triggers": [
      {
        "id": "radio_presence_detected",
        "title": {
          "en": "Radio sensing presence detected",
          "fr": "Présence détectée par radio (LQI)"
        }
      }
    ],
    "conditions": [
      {
        "id": "is_radio_presence_detected",
        "title": {
          "en": "Radio presence is detected",
          "fr": "Présence radio détectée"
        }
      }
    ],
    "actions": [
      {
        "id": "calibrate_virtual_energy",
        "title": {
          "en": "Calibrate virtual energy",
          "fr": "Calibrer l'énergie virtuelle"
        },
        "args": [
          {
            "name": "watts",
            "type": "number",
            "placeholder": {
              "en": "Nominal Watts",
              "fr": "Watts nominaux"
            }
          }
        ]
      },
      {
        "id": "set_sensing_threshold",
        "title": {
          "en": "Set radio sensing sensitivity",
          "fr": "Régler la détection radio"
        },
        "args": [
          {
            "name": "threshold",
            "type": "number",
            "placeholder": "2-50"
          }
        ]
      }
    ]
  }
