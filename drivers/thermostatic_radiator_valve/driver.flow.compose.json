      },
      "titleFormatted": {
        "en": "Set frost protection to [[mode]]"
      },
      "args": [
        {
          "name": "mode",
          "type": "dropdown",
          "values": [
            {
              "id": "on",
              "label": {
                "en": "On"
              }
            },
            {
              "id": "off",
              "label": {
                "en": "Off"
              }
            }
          ]
        }
      ]
    },
