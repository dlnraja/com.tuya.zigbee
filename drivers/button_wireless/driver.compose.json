    "learnmode": {
      "instruction": {
        "en": "Press and hold the reset button for 5 seconds until the LED blinks rapidly",
        "fr": "Appuyez et maintenez le bouton reset pendant 5 secondes jusqu'à ce que la LED clignote rapidement",
        "nl": "Houd de resetknop 5 seconden ingedrukt totdat de LED snel knippert",
        "de": "Halten Sie die Reset-Taste 5 Sekunden lang gedrückt, bis die LED schnell blinkt",
        "it": "Tenere premuto il pulsante di reset per 5 secondi fino a quando il LED lampeggia rapidamente",
        "sv": "Håll återställningsknappen intryckt i 5 sekunder tills lysdioden blinkar snabbt",
        "no": "Hold tilbakestillingsknappen inne i 5 sekunder til LED-en blinker raskt",
        "es": "Mantenga presionado el botón de reinicio durante 5 segundos hasta que el LED parpadee rápidamente",
        "da": "Hold nulstillingsknappen inde i 5 sekunder, indtil LED'en blinker hurtigt"
      }
