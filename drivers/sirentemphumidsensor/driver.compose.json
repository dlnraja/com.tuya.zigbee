{
  "id": "sirentemphumidsensor",
  "name": {
    "en": "Siren, Temperature & Humidity Sensor",
    "fr": "Sirène, Capteur de Température et d'Humidité",
    "nl": "Sirene, Temperatuur- en Vochtigheidssensor",
    "de": "Sirene, Temperatur- und Feuchtigkeitssensor",
