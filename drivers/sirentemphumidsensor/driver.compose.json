  },
  "class": "other",
  "capabilities": [
    "onoff",
    "measure_temperature",
    "measure_humidity",
    "alarm_battery",
    "alarm_siren",
    "measure_radio_stability",
    "measure_maintenance_score"
  ],
  "capabilitiesOptions": {
    "onoff": {
      "greyout": false
    }
  },
