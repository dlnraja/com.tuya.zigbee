# HOMEYIGNORE - Clean App Package
# Only runtime files go to Homey. Everything else excluded.

# === CI/CD & Dev Infrastructure ===
.github/
.githooks/
.git/
.windsurf/
.vscode/
.idea/
.vs/
scripts/
tools/
docs/
references/
backup/
project-data/
data/
diagnostics/
reports/
logs/
.archive/

# === Dev config files ===
.cascade
.windsurfrules
.cursorrules
.nycrc
.prettierrc
.prettierrc.*
.prettierignore
.eslintrc.*
eslint.config.js
jest.config.js
karma.conf.js
babel.config.js
webpack.config.js
rollup.config.js
vite.config.js
.env
.env.*
config.local.js
secrets.json

# === Root junk files ===
_cmp.js
nul
post_log.txt
tmp_validate_log.txt
README.txt

# === Build/cache/deps ===
node_modules/
.npm/
.nyc_output/
.homeybuild/
build/
dist/
out/
target/
temp/
tmp/
package-lock.json

# === Large lib/data files (dev-only, not imported at runtime) ===
lib/data/categorized_devices.json
lib/data/enrichment_data.json
lib/data/fingerprints_raw.json
lib/data/fingerprint_map.json
lib/data/generated_fingerprints.json
lib/data/model_manufacturer_map.json
lib/data/new_fingerprints.js
lib/data/new_fingerprints.json
lib/data/smart_fingerprints.js
lib/data/z2m_devices.json
lib/data/z2m_devices_full.json
# NOTE: lib/data/SourceCredits.js IS runtime - do NOT exclude

# === Dev-only engine (not imported by any runtime code) ===
lib/tuya-dp-engine/

# === Documentation (not needed at runtime) ===
**/*.md
*.md
CHANGELOG.md
CONTRIBUTING.md
LICENSE

# === File types not needed ===
*.ps1
*.cmd
*.bat
*.csv
**/*.csv
*.log
*.tmp
*.zip
*.tar.gz
*.rar
*.7z
*.bak
*.old
*.orig
*.swp
*.swo
*~
backup-*
**/*.backup*
**/*.bak

# === OS files ===
.DS_Store
Thumbs.db
desktop.ini

# === Test files ===
test/
tests/
spec/
*.test.js
*.spec.js

# === Audit files ===
MANUFACTURER_IDS_AUDIT.json
**/MANUFACTURER_IDS_AUDIT.json
*.analysis.json

# === Learnmode SVGs (optional, reduces payload) ===
**/learnmode.svg

# === KEEP these (required for App Store): ===
# .homeychangelog.json - required
# drivers/*/assets/images/small.png (75x75) - required
# drivers/*/assets/images/large.png (500x500) - required
# drivers/*/assets/images/xlarge.png (1000x1000) - recommended
# drivers/*/assets/icon.svg - required