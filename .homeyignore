# === Documentation ===
# NOTE: README.txt IS REQUIRED by SDK (App.js:1427 throws if missing)
# NOTE: README.*.txt ARE required for multilingual App Store descriptions
# NOTE: README.md is kept for GitHub visibility
CHANGELOG.md
CONTRIBUTING.md
LICENSE
AI_CONTEXT_MANDATE.md
AI_INSTRUCTIONS.md
CODE_OF_CONDUCT.md
GLOBAL_IMPROVEMENT_PLAN.md
PROJECT_INDEX.md
# README.txt            ← DO NOT EXCLUDE — REQUIRED BY ATHOM SDK
# README.nl.txt         ← DO NOT EXCLUDE — App Store NL description
# README.de.txt         ← DO NOT EXCLUDE — App Store DE description
# README.fr.txt         ← DO NOT EXCLUDE — App Store FR description
drivers/**/README.txt

