# === RUNTIME FILES ŌĆö DO NOT EXCLUDE (required for App Store & Runtime) ===
# app.json                          ŌåÉ Homey manifest
# package.json                      ŌåÉ Node package
# .homeychangelog.json              ŌåÉ Store changelog
# driver-mapping-database.json      ŌåÉ DriverMappingLoader.js
# data/fingerprints.json            ŌåÉ DeviceFingerprintDB.js (lazy-loaded)
# lib/tuya/fingerprints.json        ŌåÉ tuya-engine/index.js:14
# lib/tuya/profiles.json            ŌåÉ tuya-engine/index.js:15
# lib/tuya/capability-map.json      ŌåÉ tuya-dp-engine
# locales/*.json                    ŌåÉ lib/util/index.js:131
# assets/icon.svg                   ŌåÉ Athom SDK3 App.js:618 (iconHash)
# assets/images/small.png           ŌåÉ Required
# assets/images/large.png           ŌåÉ Required
# drivers/*/assets/icon.svg         ŌåÉ Required per driver
# drivers/*/assets/images/small.png ŌåÉ Required
# drivers/*/assets/images/large.png ŌåÉ Required